        tween(yesBtn, TweenInfo.new(0.1), { BackgroundColor3 = accentColor })
    end)
    noBtn.MouseEnter:Connect(function()
        tween(noBtn, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(65, 65, 65) })
    end)
    noBtn.MouseLeave:Connect(function()
        tween(noBtn, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(45, 45, 45) })
    end)

    -- Play GTA notification sound
    local notifySound = mk("Sound", {
        Parent = SoundService,
        SoundId = GTA_NOTIFY_SOUND,
        Volume = 0.3
    })

    -- Slide in from bottom-left
    task.delay(0.15, function()
        pcall(function() notifySound:Play() end)
        tween(container, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
