        dismissed = true
        tween(container, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            Position = UDim2.new(0, -420, 1, -20)
        })
        task.delay(0.4, function()
            container:Destroy()
            if notifySound then notifySound:Destroy() end
            if callback then callback() end
        end)
    end

    yesBtn.MouseButton1Click:Connect(function()
        dismiss(onYes)
    end)

    noBtn.MouseButton1Click:Connect(function()
        dismiss(onNo)
    end)

    return container, dismiss
end

