-- ═══════════════════════════════════════════════════════════════
-- RENDER MENU (with bootloader filtering)
-- ═══════════════════════════════════════════════════════════════

GmmUI._renderMenu = function(self, menu)
    self:_clearRows()
    self.Current = menu

    -- Filter items: separate supported and unsupported
    local activeItems = {}
    local disabledItems = {}

    for _, item in ipairs(menu.Items) do
        if item.RequiredFunctions and self._scanData then
            if Bootloader.CheckFeature(self._scanData, item.RequiredFunctions) then
                table.insert(activeItems, item)
            else
                table.insert(disabledItems, item)
            end
        else
            table.insert(activeItems, item)
        end
    end

    -- Store the active items list for navigation
    menu._activeItems = activeItems

    self:SetTab(menu.Name)

    local layoutOrder = 0

    -- Render active (working) items first
    for i, item in ipairs(activeItems) do
        layoutOrder += 1
        local row, setSelected, refreshValue = self:_makeRow(item, i)
        row.LayoutOrder = layoutOrder
        item.__row = row
        item.__setSelected = setSelected
        item.__refreshValue = refreshValue
        table.insert(self._rowObjects, row)
    end

    -- Render disabled (strikethrough) items after — they are visual-only
    for _, item in ipairs(disabledItems) do
        layoutOrder += 1
        local row = self:_makeDisabledRow(item, layoutOrder)
        table.insert(self._rowObjects, row)
    end

    if #activeItems > 0 then
        local savedY = tonumber(menu._savedCanvasY) or 0

        if self._scrollTween then
            pcall(function() self._scrollTween:Cancel() end)
            self._scrollTween = nil
        end

        self.Scroll.CanvasPosition = Vector2.new(0, savedY)
        self._scrollTargetY = savedY

        local savedIdx = tonumber(menu._savedIndex)
        if not (savedIdx and savedIdx >= 1 and savedIdx <= #activeItems) then
            savedIdx = 1
        end

        self:SetSelected(savedIdx, true)
    else
        self.SelectedIndex = 0
        self.DescLabel.Text = "No options available."
        self:_updateCounter()
    end
end

GmmUI.PushMenu = function(self, menu)
    self:_saveMenuState()
    table.insert(self.MenuStack, menu)
    self:_renderMenu(menu)
end

GmmUI.Back = function(self)
    if self._edit then
        self:CancelEdit()
        return
    end

    if #self.MenuStack <= 1 then
        self:Close()
        return
    end

    self:_playSound("Back")
    self:_saveMenuState()
    table.remove(self.MenuStack, #self.MenuStack)
    local top = self.MenuStack[#self.MenuStack]
    self:_renderMenu(top)
end

-- ═══════════════════════════════════════════════════════════════
-- SCROLLING
-- ═══════════════════════════════════════════════════════════════

GmmUI._scrollTo = function(self, targetY)
    local scroll = self.Scroll
    if not scroll then return end

    targetY = tonumber(targetY) or 0
    self._scrollTargetY = targetY

    local absCanvasY = scroll.AbsoluteCanvasSize.Y
    local maxY = (absCanvasY > 0) and math.max(0, absCanvasY - scroll.AbsoluteSize.Y) or math.huge
    targetY = math.clamp(targetY, 0, maxY)

    if self._scrollTween then
        pcall(function() self._scrollTween:Cancel() end)
        self._scrollTween = nil
    end

    local smoothness = tonumber(self.Opts and self.Opts.ScrollSmoothness) or 0
    if smoothness <= 0 then
        scroll.CanvasPosition = Vector2.new(0, targetY)
        self._scrollTargetY = targetY
        return
    end

    local duration = math.clamp(0.04 * smoothness, 0.05, 0.3)
    self._scrollTween = tween(scroll, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
        CanvasPosition = Vector2.new(0, targetY)
    })
end

-- ═══════════════════════════════════════════════════════════════
-- SELECTION
-- ═══════════════════════════════════════════════════════════════

GmmUI.SetSelected = function(self, idx, silent)
    if not self.Current then return end

    local items = self.Current._activeItems or self.Current.Items
    if #items == 0 then return end

    local previous = self.SelectedIndex
    idx = ((idx - 1) % #items) + 1
    self.SelectedIndex = idx

    for i, it in ipairs(items) do
        if it.__setSelected then
            it.__setSelected(i == idx)
        end
    end

    local it = items[idx]
    self.DescLabel.Text = (it and it.Desc and it.Desc ~= "" and it.Desc) or "Select an option."
    self:_updateCounter()

    local row = it and it.__row
    if row then
        local margin = 4
        local y = row.AbsolutePosition.Y
        local h = row.AbsoluteSize.Y
        local topY = self.Scroll.AbsolutePosition.Y
        local botY = topY + self.Scroll.AbsoluteSize.Y

        if y < (topY + margin) then
            self:_scrollTo(self.Scroll.CanvasPosition.Y - ((topY + margin) - y))
        elseif (y + h) > (botY - margin) then
            self:_scrollTo(self.Scroll.CanvasPosition.Y + ((y + h) - (botY - margin)))
        end
    end

    self:_saveMenuState()

    if not silent and previous ~= idx and self.Opened then
        self:_playSound("Move")
    end
end

GmmUI._getSelectedItem = function(self)
    if not self.Current then return nil end
    local items = self.Current._activeItems or self.Current.Items
    return items[self.SelectedIndex]
end

-- ═══════════════════════════════════════════════════════════════
-- HOLD / EDIT / ACTIONS
-- ═══════════════════════════════════════════════════════════════

GmmUI._stopHold = function(self, dir)
    if dir == nil or self._holdDir == dir then
        self._holdDir = nil
        self._holdToken = (self._holdToken or 0) + 1
    end
end

GmmUI._startHold = function(self, dir)
    local it = self._edit and self._edit.Item
    if not (self.Opened and it and it == self:_getSelectedItem() and it.Type == "Slider") then
        return
    end

    self._holdDir = dir
    self._holdToken = (self._holdToken or 0) + 1
    local token = self._holdToken

    task.spawn(function()
        task.wait(0.35)
        while self._holdToken == token and self._holdDir == dir do
            if not self.Opened then break end
            if not self._edit or self._edit.Item ~= it then break end
            if dir < 0 then self:DoLeft() else self:DoRight() end
            task.wait(0.05)
        end
    end)
end

GmmUI.BeginEdit = function(self)
    if self._edit then return end
    local it = self:_getSelectedItem()
    if not it or it.Type ~= "Slider" then return end

    self._edit = {
        Item = it,
        Original = (it.Get and it.Get()) or nil
    }

    if it.__refreshValue then it.__refreshValue() end
    self:_playSound("Select")
end

GmmUI.ConfirmEdit = function(self)
    if not self._edit then return end
    local it = self._edit.Item
    self._edit = nil
    self:_stopHold()
    if it and it.__refreshValue then it.__refreshValue() end
    self:_playSound("Select")
end

GmmUI.CancelEdit = function(self)
    if not self._edit then return end
    local it = self._edit.Item
    local original = self._edit.Original
    self._edit = nil
    self:_stopHold()

    if it and original ~= nil and it.Set then
        it.Set(original)
    end
    if it and it.__refreshValue then it.__refreshValue() end
    self:_playSound("Back")
end

GmmUI.DoLeft = function(self)
    local it = self:_getSelectedItem()
    if not it then return end
    if it.Type == "Slider" then
        if not (self._edit and self._edit.Item == it) then return end
    end
    if it.Left then
        it:Left()
        if it.__refreshValue then it.__refreshValue() end
        self:_playSound("Change")
    end
end

GmmUI.DoRight = function(self)
    local it = self:_getSelectedItem()
    if not it then return end
    if it.Type == "Slider" then
        if not (self._edit and self._edit.Item == it) then return end
    end
    if it.Right then
        it:Right()
        if it.__refreshValue then it.__refreshValue() end
        self:_playSound("Change")
    end
end

GmmUI.Select = function(self)
    local it = self:_getSelectedItem()
    if not it then return end

    if it.Type == "Slider" then
        if self._edit and self._edit.Item == it then
            self:ConfirmEdit()
        else
            self:BeginEdit()
        end
        return
    end

    if it.Type == "Toggle" or it.Type == "List" then
        self:_playSound("Change")
    else
        self:_playSound("Select")
    end

    if it.Activate then
        it:Activate()
        if it.__refreshValue then it.__refreshValue() end
    end
end

-- ═══════════════════════════════════════════════════════════════
-- 3D UI TILT EFFECT
-- ═══════════════════════════════════════════════════════════════

GmmUI.Set3DEnabled = function(self, enabled)
    self._3dEnabled = enabled

    if enabled then
        if self._3dConnection then return end -- already connected

        self._3dConnection = RunService.RenderStepped:Connect(function()
            if not self.Opened or not self.Main or not self.Main.Parent then
                self.Main.Rotation = 0
                return
            end

            local mousePos = UserInputService:GetMouseLocation()
            local viewportSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)

            -- Normalize mouse position to -1..1
            local nx = ((mousePos.X / viewportSize.X) - 0.5) * 2
            local ny = ((mousePos.Y / viewportSize.Y) - 0.5) * 2

            -- Tilt parameters
            local maxRotation = 3  -- degrees
            local maxSkewX = 0.015
            local maxSkewY = 0.012

            -- Apply rotation based on horizontal mouse position
            local targetRotation = nx * maxRotation
            local currentRotation = self.Main.Rotation
            self.Main.Rotation = currentRotation + (targetRotation - currentRotation) * 0.12

            -- Apply subtle perspective offset via position nudge
            if self._3dBasePosition then
                local offsetX = nx * 4
                local offsetY = ny * 3
                self.Main.Position = UDim2.new(
                    self._3dBasePosition.X.Scale,
                    self._3dBasePosition.X.Offset + offsetX,
                    self._3dBasePosition.Y.Scale,
                    self._3dBasePosition.Y.Offset + offsetY
                )
                self.Shadow.Position = UDim2.new(
                    self._3dBasePosition.X.Scale,
                    self._3dBasePosition.X.Offset + offsetX + 4 + (nx * 3),
                    self._3dBasePosition.Y.Scale,
                    self._3dBasePosition.Y.Offset + offsetY + 6 + (ny * 3)
                )
            end
        end)
    else
        if self._3dConnection then
            self._3dConnection:Disconnect()
            self._3dConnection = nil
        end

        -- Reset transform
        if self.Main then
            self.Main.Rotation = 0
            if self._3dBasePosition then
                self.Main.Position = self._3dBasePosition
                self.Shadow.Position = offsetUDim2(self._3dBasePosition, 4, 6)
            end
        end
    end
end

-- ═══════════════════════════════════════════════════════════════
-- OPEN / CLOSE / TOGGLE (Slide-in from Left)
-- ═══════════════════════════════════════════════════════════════

-- Target position: overlapping the Roblox top-bar area (top-left)
local OPEN_POSITION = UDim2.new(0, 6, 0, 4)
-- Off-screen to the left
local CLOSED_OFFSET_X = -350

GmmUI.Open = function(self)
    if self.Opened then return end
    self.Opened = true

    self.Overlay.Visible = true
    self.Shadow.Visible = true
    self.Main.Visible = true

    -- Start off-screen
    self.Main.Position = UDim2.new(0, CLOSED_OFFSET_X, OPEN_POSITION.Y.Scale, OPEN_POSITION.Y.Offset)
    self.Shadow.Position = UDim2.new(0, CLOSED_OFFSET_X + 4, OPEN_POSITION.Y.Scale, OPEN_POSITION.Y.Offset + 6)

    self.Overlay.BackgroundTransparency = 1
    self.Shadow.BackgroundTransparency = 1
    self.Main.BackgroundTransparency = 0.06

    -- Slide in
    local slideInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

    tween(self.Main, slideInfo, {
        Position = OPEN_POSITION
    })
    tween(self.Shadow, slideInfo, {
        Position = offsetUDim2(OPEN_POSITION, 4, 6),
        BackgroundTransparency = 0.7
    })
    tween(self.Overlay, TweenInfo.new(0.2, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0.58
    })

    -- Store base position for 3D effect
    self._3dBasePosition = OPEN_POSITION

    self:_playSound("Open")
end

GmmUI.Close = function(self)
    if not self.Opened then return end

    if self._edit then
        self:ConfirmEdit()
    else
        self:_stopHold()
    end

    self.Opened = false
    self:_playSound("Close")

    -- Disable 3D tilt on close, reset rotation
    if self._3dConnection then
        self._3dConnection:Disconnect()
        self._3dConnection = nil
    end
    self.Main.Rotation = 0

    -- Slide out to left
    local slideInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    local closedPos = UDim2.new(0, CLOSED_OFFSET_X, OPEN_POSITION.Y.Scale, OPEN_POSITION.Y.Offset)

    tween(self.Main, slideInfo, {
        Position = closedPos
    })
    tween(self.Shadow, slideInfo, {
        Position = offsetUDim2(closedPos, 4, 6),
        BackgroundTransparency = 1
    })
    local a = tween(self.Overlay, TweenInfo.new(0.2, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {
        BackgroundTransparency = 1
    })

    a.Completed:Connect(function()
        if not self.Opened then
            self.Overlay.Visible = false
            self.Shadow.Visible = false
            self.Main.Visible = false
        end
    end)

    -- Re-enable 3D if it was toggled on (will reactivate on next Open)
    if self._3dEnabled then
        task.delay(0.4, function()
            if self.Opened and self._3dEnabled and not self._3dConnection then
                self:Set3DEnabled(true)
            end
        end)
    end
end

GmmUI.Toggle = function(self)
    if self.Opened then
        self:Close()
    else
        self:Open()
        -- Re-enable 3D tilt if toggle is on
        if self._3dEnabled then
            task.delay(0.45, function()
                if self.Opened and self._3dEnabled then
                    self:Set3DEnabled(true)
                end
            end)
        end
    end
end

-- ═══════════════════════════════════════════════════════════════
-- DESTROY
-- ═══════════════════════════════════════════════════════════════

GmmUI.Destroy = function(self)
    -- Disconnect 3D
    if self._3dConnection then
        self._3dConnection:Disconnect()
        self._3dConnection = nil
    end

    for _, c in ipairs(self._connections) do
        pcall(function() c:Disconnect() end)
    end
    self._connections = {}

    if self._casActions then
        for _, name in ipairs(self._casActions) do
            pcall(function() ContextActionService:UnbindAction(name) end)
        end
        self._casActions = nil
    end

    if self.SoundFolder then
        self.SoundFolder:Destroy()
        self.SoundFolder = nil
    end

    -- Restore Roblox top bar
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.PlayerList, true) end)
    pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.EmotesMenu, true) end)

    if self.Gui then
        self.Gui:Destroy()
    end
end

