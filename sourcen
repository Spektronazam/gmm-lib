-- BOOTLOADER — UNC / FUNCTION SCANNER
-- ═══════════════════════════════════════════════════════════════

--[[
    The bootloader scans for executor-level functions before the UI opens.
    Each feature can declare a list of required functions. If any required
    function is missing, the feature gets a visible strikethrough label and
    is omitted from the interactive menu. A UIListLayout ensures working
    features slide up to fill the gaps — no empty rows.

    After scanning, a GTA V–style notification slides in from the bottom-left:
      • Low UNC  → "Your executor doesn't support some features, run anyways?"
      • High UNC → "Your executor supports every feature, continue to run?"
    The user must press YES or NO before the main UI appears.
]]

local Bootloader = {}
Bootloader.__index = Bootloader

-- GTA V notification sound IDs for Roblox
-- These approximate the iconic GTA V phone/notification chime
local GTA_NOTIFY_SOUND_IDS = {
    "rbxassetid://156785206",   -- short electronic chime (closest match)
    "rbxassetid://3512757463",  -- notification ping
    "rbxassetid://6518811702",  -- clean UI notification
    "rbxassetid://4590657391",  -- phone buzz/chime
    "rbxassetid://9125402735",  -- soft notification ding
}

-- Primary notification sound used for the bootloader GTA banner
local GTA_NOTIFY_SOUND = GTA_NOTIFY_SOUND_IDS[1]

-- Functions to scan for — maps function name → global reference
local UNC_FUNCTIONS = {
    -- Filesystem
    "readfile", "writefile", "appendfile", "loadfile", "listfiles",
    "isfile", "isfolder", "makefolder", "delfolder", "delfile",
    -- HTTP
    "request", "http_request", "syn_request",
    -- Clipboard
    "setclipboard", "toclipboard",
    -- Environment
    "getgenv", "getrenv", "getfenv", "setfenv",
    "getsenv", "getmenv",
    -- Instances
    "gethiddenproperty", "sethiddenproperty",
    "getinstances", "getnilinstances",
    "fireclickdetector", "firetouchinterest", "fireproximityprompt",
    -- Scripts
    "getscripts", "getrunningscripts", "getloadedmodules",
    "decompile", "saveinstance",
    -- Hooking / closures
    "hookfunction", "hookmetamethod", "newcclosure",
    "getnamecallmethod", "iscclosure", "islclosure",
    "getinfo", "getupvalue", "setupvalue",
    "getupvalues", "getconstant", "setconstant", "getconstants",
    -- Drawing
    "Drawing", "Drawing.new",
    -- Crypt
    "crypt", "base64_encode", "base64_decode",
    -- Misc
    "setfpscap", "isexecutorclosure", "checkcaller",
    "getthreadidentity", "setthreadidentity",
    "isrbxactive", "mouse1click", "mouse2click",
    "keypress", "keyrelease",
}

function Bootloader.ScanFunctions()
    local results = {}
    local passed = 0
    local failed = 0

    for _, name in ipairs(UNC_FUNCTIONS) do
        local found = false
        -- Handle dotted names like "Drawing.new"
        if string.find(name, "%.") then
            local parts = string.split(name, ".")
            local ref = getfenv(0)
            local ok = true
            for _, part in ipairs(parts) do
                if typeof(ref) == "table" or typeof(ref) == "userdata" then
                    local s, r = pcall(function() return ref[part] end)
                    if s and r ~= nil then
                        ref = r
                    else
                        ok = false
                        break
                    end
                else
                    ok = false
                    break
                end
            end
            found = ok
        else
            local s, r = pcall(function()
                return getfenv(0)[name]
            end)
            if s and r ~= nil then
                found = true
            else
                -- Also check _G and shared
                local s2, r2 = pcall(function() return _G[name] end)
                if s2 and r2 ~= nil then
                    found = true
                else
                    local s3, r3 = pcall(function() return shared[name] end)
                    if s3 and r3 ~= nil then
                        found = true
                    end
                end
            end
        end

        results[name] = found
        if found then
            passed += 1
        else
            failed += 1
        end
    end

    return {
        Results = results,
        Passed = passed,
        Failed = failed,
        Total = passed + failed,
        FullSupport = (failed == 0),
        Percentage = (passed / math.max(passed + failed, 1)) * 100
    }
end

-- Check whether a feature's required functions are all available
function Bootloader.CheckFeature(scanResults, requiredFunctions)
    if not requiredFunctions or #requiredFunctions == 0 then
        return true
    end
    for _, funcName in ipairs(requiredFunctions) do
        if not scanResults.Results[funcName] then
            return false
        end
    end
    return true
end

