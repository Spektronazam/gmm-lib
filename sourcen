local function mk(className, props)
    local inst = Instance.new(className)
    for key, value in pairs(props or {}) do
        inst[key] = value
    end
    return inst
end

local function tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function mix(a, b, alpha)
    return Color3.new(
        a.R + (b.R - a.R) * alpha,
        a.G + (b.G - a.G) * alpha,
        a.B + (b.B - a.B) * alpha
    )
end

local function lighten(color, amount)
    return mix(color, Color3.new(1, 1, 1), amount)
end

local function darken(color, amount)
    return mix(color, Color3.new(0, 0, 0), amount)
end

local function smartShift(color, amount)
    local lum = (0.2126 * color.R) + (0.7152 * color.G) + (0.0722 * color.B)
    if lum > 0.6 then
        return darken(color, amount)
    end
    return lighten(color, amount)
end

local function cloneTable(tbl)
    local new = {}
    for key, value in pairs(tbl or {}) do
        if typeof(value) == "table" then
            local inner = {}
            for innerKey, innerValue in pairs(value) do
                inner[innerKey] = innerValue
            end
            new[key] = inner
        else
            new[key] = value
        end
    end
    return new
end

local function applyTable(into, from)
    for key, value in pairs(from or {}) do
        if typeof(value) == "table" and typeof(into[key]) == "table" then
            for innerKey, innerValue in pairs(value) do
                into[key][innerKey] = innerValue
            end
        else
            into[key] = value
        end
    end
    return into
end

local function addCorner(obj, radius)
    return mk("UICorner", {
        Parent = obj,
        CornerRadius = UDim.new(0, math.max(0, tonumber(radius) or 0))
    })
end

local function addStroke(obj, color, transparency, thickness)
    return mk("UIStroke", {
        Parent = obj,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Color = color,
        Transparency = transparency or 0,
        Thickness = thickness or 1
    })
end

local function addPadding(obj, left, right, top, bottom)
    return mk("UIPadding", {
        Parent = obj,
        PaddingLeft = UDim.new(0, left or 0),
        PaddingRight = UDim.new(0, right or 0),
        PaddingTop = UDim.new(0, top or 0),
        PaddingBottom = UDim.new(0, bottom or 0)
    })
end

local function offsetUDim2(pos, x, y)
    return UDim2.new(
        pos.X.Scale,
        pos.X.Offset + (x or 0),
        pos.Y.Scale,
        pos.Y.Offset + (y or 0)
    )
end

local function gtaText(value)
    return string.upper(tostring(value or ""))
end

local function safeParentGui()
    local lp = Players.LocalPlayer
    local pg = lp and lp:FindFirstChildOfClass("PlayerGui")
    if pg then return pg end
    return game:GetService("CoreGui")
end

