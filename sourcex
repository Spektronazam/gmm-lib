function G:Set3D(on)
	self._3d = on and true or false
	if self._3dc then self._3dc:Disconnect(); self._3dc=nil end
	if not on then self.Mn.Rotation=0; return end
	self._3dc = rs.RenderStepped:Connect(function()
		if not self.Opened or not self._3d then return end
		local mp = uis:GetMouseLocation()
		local ap = self.Wrap.AbsolutePosition
		local az = self.Wrap.AbsoluteSize
		if az.X==0 or az.Y==0 then return end
		local rx = math.clamp(((mp.X-ap.X)/az.X)*2-1,-1.5,1.5)
		local ang = self.O.Perspective3DAngle or 8
		local tgt = rx * ang * 0.3
		self.Mn.Rotation = self.Mn.Rotation + (tgt - self.Mn.Rotation) * 0.1
	end)
end

function G:_mksnds()
	if self.SndF then self.SndF:Destroy(); self.SndF=nil end
	self.Snds = {}
	self.SndF = mk("Folder",{Name="GmmUI_Snd",Parent=ss})
	for nm, id in pairs(self.O.SoundIds or {}) do
		if tostring(id or "")~="" then
			self.Snds[nm] = mk("Sound",{
				Name=nm,Parent=self.SndF,SoundId=tostring(id),
				Volume=tonumber(self.O.SoundVolume) or 0.18
			})
		end
	end
end

function G:_snd(nm)
	if not self.O.UseSounds then return end
	local tpl = self.Snds and self.Snds[nm]
	if not tpl then return end
	local s = tpl:Clone()
	s.Parent = self.SndF
	s.Volume = tonumber(self.O.SoundVolume) or s.Volume
	pcall(function() s:Play() end)
	s.Ended:Connect(function() if s then s:Destroy() end end)
	task.delay(5,function() if s and s.Parent then s:Destroy() end end)
end

function G:EnableSounds(on) self.O.UseSounds = on and true or false end

function G:SetSoundVolume(v)
	self.O.SoundVolume = math.clamp(tonumber(v) or self.O.SoundVolume or 0.18, 0, 1)
	for _, tpl in pairs(self.Snds or {}) do tpl.Volume = self.O.SoundVolume end
end

function G:NewMenu(nm) return M.new(self, nm) end
function G:SetTitle(t) self.Ttl.Text = up(t) end
