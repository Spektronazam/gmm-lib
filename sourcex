function G:_ncol(k)
	if typeof(k)=="Color3" then return k end
	local l = string.lower(tostring(k or "info"))
	if l=="success" then return Color3.fromRGB(80,190,110)
	elseif l=="warning" then return Color3.fromRGB(255,170,35)
	elseif l=="error" then return Color3.fromRGB(255,74,74) end
	return self.O.Accent
end

function G:_restylenots()
	for i=#self._nots,1,-1 do
		local d = self._nots[i]
		if not d.Fr or d.Fr.Parent==nil then
			table.remove(self._nots,i)
		else
			local ac = self:_ncol(d.Kind)
			d.Fr.BackgroundColor3=Color3.fromRGB(10,10,10)
			d.Str.Color=self.O.Stroke
			d.Tl.BackgroundColor3=ac
			d.Ti.TextColor3=self.O.Text
			d.Bd.TextColor3=self.O.Text
			d.Cl.TextColor3=self.O.MutedText
			d.Ab.BackgroundColor3=ac
			d.Lb.BackgroundColor3=Color3.fromRGB(55,55,55)
			d.Lf.BackgroundColor3=ac
		end
	end
end

