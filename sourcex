function G:SetTheme(th)
	local no = dupe(self.O)
	if typeof(th)=="string" then
		assert(THEMES[th])
		patch(no, THEMES[th])
		no.Theme=th; self.ThemeName=th
	elseif typeof(th)=="table" then
		patch(no, th)
		no.Theme="Custom"; self.ThemeName="Custom"
	else error("bad theme") end
	derive(no)
	self.O = no
	self:_mksnds()
	self:_theme()
end

