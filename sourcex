Boot.Deps = {}

function Boot.RegDep(lbl, fns) Boot.Deps[lbl] = fns end

function Boot.Scan()
	local out = {Ok={},Nope={},Tot=0,Nok=0,Nfail=0,Pct=0,High=false}
	for _, pr in ipairs(Boot.PROBES) do
		local gn, dn, cat = pr[1], pr[2], pr[3]
		out.Tot += 1
		local hit = false
		pcall(function()
			local e = getfenv(0)
			if e[gn] ~= nil then hit=true; return end
			if _G[gn] ~= nil then hit=true; return end
			if shared and shared[gn] ~= nil then hit=true; return end
			if rawget(_G,gn) ~= nil then hit=true end
		end)
		if not hit then
			pcall(function()
				if typeof(getfenv(0)[gn])=="function" then hit=true end
			end)
		end
		if hit then
			out.Nok += 1
			table.insert(out.Ok, {Name=dn, Cat=cat})
		else
			out.Nfail += 1
			table.insert(out.Nope, {Name=dn, Cat=cat})
		end
	end
	out.Pct = out.Tot > 0 and (out.Nok/out.Tot) or 0
	out.High = out.Pct >= 0.7
	return out
end

function Boot.Chk(lbl, scan)
	local d = Boot.Deps[lbl]
	if not d then return true end
	local fm = {}
	for _, f in ipairs(scan.Nope) do fm[f.Name]=true end
	for _, rn in ipairs(d) do
		if fm[rn] then return false end
	end
	return true
end

