function M:Button(lbl, desc, cb, reqs)
	local itm = self:_add({
		Type="Button",Label=tostring(lbl),Desc=tostring(desc or ""),
		Reqs=reqs,Ok=true,
		Activate=function()
			if typeof(cb)=="function" then task.spawn(cb) end
