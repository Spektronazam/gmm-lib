	local function vbg()
		if dead then return o.Pill end
		if sel then return Color3.fromRGB(235,235,235) end
		if itm.Type=="Toggle" and itm.Get and itm.Get() then return o.Accent end
		if itm.Type=="Slider" and self._ed and self._ed.Itm==itm then return lerpc3(o.Accent,o.Pill,0.2) end
		return o.Pill
	end

	local function vtc()
		if dead then return Color3.fromRGB(100,100,100) end
		if sel then return o.SelectedText or Color3.fromRGB(12,12,12) end
		if itm.Type=="Toggle" and itm.Get and itm.Get() then return Color3.fromRGB(255,255,255) end
		return o.Text
	end

	local function uvt()
		if not rtxt then return end
		local v = up(itm:ValueText())
		if itm.Type=="Slider" and self._ed and self._ed.Itm==itm then
			rtxt.Text = "\226\128\185 "..v.." \226\128\186"
		elseif itm.Type=="List" and sel then
			rtxt.Text = "\226\128\185 "..v.." \226\128\186"
		else rtxt.Text = v end
	end

	local function vis(anim)
		if dead then
			row.BackgroundColor3=dim(o.Row,0.3)
			row.BackgroundTransparency=0.4
			selbg.BackgroundTransparency=1
			abar.BackgroundTransparency=1
			return
		end
		local rc = hov and o.RowHover or o.Row
		local tc = sel and (o.SelectedText or Color3.fromRGB(12,12,12)) or o.Text
		local ac2 = sel and tc or o.MutedText
		if anim then
			local ti = TweenInfo.new(0.08,Enum.EasingStyle.Linear,Enum.EasingDirection.Out)
			tw(row,ti,{BackgroundColor3=rc})
			tw(selbg,ti,{BackgroundTransparency=sel and 0 or 1})
			tw(abar,ti,{BackgroundTransparency=sel and 0 or 1})
			tw(rstr,ti,{Color=sel and o.Accent or o.Stroke, Transparency=sel and 0.4 or 0.82})
		else
			row.BackgroundColor3=rc
			selbg.BackgroundTransparency=sel and 0 or 1
			abar.BackgroundTransparency=sel and 0 or 1
			rstr.Color=sel and o.Accent or o.Stroke
			rstr.Transparency=sel and 0.4 or 0.82
		end
		ltxt.TextColor3=tc
		if arr then arr.TextColor3=ac2 end
		if rtxt then
			rtxt.TextColor3=vtc()
			vbtn.BackgroundColor3=vbg()
			vstr.Color=sel and o.Accent or o.Stroke
		end
	end

	local function refresh() uvt(); vis(false) end
	local function setsel(on) sel=on==true; uvt(); vis(true) end
	refresh()

	row.MouseEnter:Connect(function() hov=true; vis(true) end)
	row.MouseLeave:Connect(function() hov=false; vis(true) end)
	row.MouseButton1Click:Connect(function()
		if not self.Opened then return end
		if dead then self:_snd("Error"); return end
		if self._ed and self._ed.Itm~=itm then return end
		self:SetSelected(idx, true)
		self:Select()
	end)

	if vbtn then
		vbtn.MouseEnter:Connect(function() hov=true; vis(true) end)
		vbtn.MouseLeave:Connect(function() hov=false; vis(true) end)
		vbtn.MouseButton1Down:Connect(function(x)
			if not self.Opened or dead then return end
			if self._ed and self._ed.Itm~=itm then return end
			self:SetSelected(idx, true)
			local mid = vbtn.AbsolutePosition.X+(vbtn.AbsoluteSize.X/2)
			local dir = (x<mid) and -1 or 1
			if itm.Type=="Slider" then
				if not (self._ed and self._ed.Itm==itm) then self:BeginEdit() end
				if dir<0 then self:DoLeft() else self:DoRight() end
			elseif itm.Type=="List" or itm.Type=="Toggle" then
				if dir<0 then self:DoLeft() else self:DoRight() end
			else self:Select() end
		end)
	end

	return row, setsel, refresh
end

function G:_render(menu)
	self:_clr()
	self.Cur = menu
	self:SetTab(menu.Name)

	for i, itm in ipairs(menu.Items) do
		local row, ss2, rf = self:_mkrow(itm, i)
		itm.__r = row
		itm.__ss = ss2
		itm.__rf = rf
		self._rows[#self._rows+1] = row
	end

	if #menu.Items > 0 then
		local sy = tonumber(menu._sy) or 0
		if self._stw then pcall(function() self._stw:Cancel() end); self._stw=nil end
		self.Scr.CanvasPosition = Vector2.new(0, sy)
		self._sty = sy

		local si = tonumber(menu._si)
		if not (si and si>=1 and si<=#menu.Items) then
			si = 1
			for j, itm in ipairs(menu.Items) do
				if itm.Ok~=false then si=j; break end
			end
		end
		self:SetSelected(si, true)
	else
		self.SelIdx = 0
		self.Desc.Text = "No options."
		self:_ucnt()
	end
end

function G:PushMenu(menu)
	self:_savest()
	self.Stack[#self.Stack+1] = menu
	self:_render(menu)
end

function G:Back()
	if self._ed then self:CancelEdit(); return end
	if #self.Stack <= 1 then self:Close(); return end
	self:_snd("Back")
	self:_savest()
	table.remove(self.Stack, #self.Stack)
	self:_render(self.Stack[#self.Stack])
end

function G:_scrto(ty)
	local scr = self.Scr
	if not scr then return end
	ty = tonumber(ty) or 0
	self._sty = ty
	local acy = scr.AbsoluteCanvasSize.Y
	local mx = (acy>0) and math.max(0, acy-scr.AbsoluteSize.Y) or math.huge
	ty = math.clamp(ty, 0, mx)
	if self._stw then pcall(function() self._stw:Cancel() end); self._stw=nil end
	local sm = tonumber(self.O and self.O.ScrollSmoothness) or 0
	if sm<=0 then scr.CanvasPosition=Vector2.new(0,ty); self._sty=ty; return end
	local dur = math.clamp(0.04*sm, 0.05, 0.3)
	self._stw = tw(scr, TweenInfo.new(dur,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), {
		CanvasPosition=Vector2.new(0,ty)
	})
end

function G:SetSelected(idx, silent)
	if not self.Cur then return end
	local items = self.Cur.Items
	if #items==0 then return end
	local prev = self.SelIdx
	idx = ((idx-1)%#items)+1
	self.SelIdx = idx

	for i, it in ipairs(items) do
		if it.__ss then it.__ss(i==idx) end
	end

	local it = items[idx]
	local dsc = (it and it.Desc and it.Desc~="" and it.Desc) or "Select an option."
	if it and it.Ok==false then
		dsc = "\226\154\160 UNSUPPORTED \226\128\148 Your executor is missing required functions for this feature."
	end
	self.Desc.Text = dsc
	self:_ucnt()

	local r = it and it.__r
	if r then
		local mg = 4
		local y = r.AbsolutePosition.Y
		local h = r.AbsoluteSize.Y
		local ty = self.Scr.AbsolutePosition.Y
		local by = ty + self.Scr.AbsoluteSize.Y
		if y < (ty+mg) then
			self:_scrto(self.Scr.CanvasPosition.Y - ((ty+mg)-y))
		elseif (y+h) > (by-mg) then
			self:_scrto(self.Scr.CanvasPosition.Y + ((y+h)-(by-mg)))
		end
	end
	self:_savest()
	if not silent and prev~=idx and self.Opened then self:_snd("Move") end
end

function G:_selitm()
	if not self.Cur then return nil end
	return self.Cur.Items[self.SelIdx]
end

function G:_stoph(dir)
	if dir==nil or self._hdir==dir then
		self._hdir=nil
		self._htok=(self._htok or 0)+1
	end
end

function G:_starth(dir)
	local it = self._ed and self._ed.Itm
	if not (self.Opened and it and it==self:_selitm() and it.Type=="Slider") then return end
	self._hdir = dir
	self._htok = (self._htok or 0)+1
	local tok = self._htok
	task.spawn(function()
		task.wait(0.35)
		while self._htok==tok and self._hdir==dir do
			if not self.Opened then break end
			if not self._ed or self._ed.Itm~=it then break end
			if dir<0 then self:DoLeft() else self:DoRight() end
			task.wait(0.05)
		end
	end)
end

function G:BeginEdit()
	if self._ed then return end
	local it = self:_selitm()
	if not it or it.Type~="Slider" or it.Ok==false then return end
	self._ed = {Itm=it, Orig=(it.Get and it.Get()) or nil}
	if it.__rf then it.__rf() end
	self:_snd("Select")
end

function G:ConfirmEdit()
	if not self._ed then return end
	local it = self._ed.Itm
	self._ed = nil
	self:_stoph()
	if it and it.__rf then it.__rf() end
	self:_snd("Select")
end

function G:CancelEdit()
	if not self._ed then return end
	local it = self._ed.Itm
	local og = self._ed.Orig
	self._ed = nil
	self:_stoph()
	if it and og~=nil and it.Set then it.Set(og) end
	if it and it.__rf then it.__rf() end
	self:_snd("Back")
end

function G:DoLeft()
	local it = self:_selitm()
	if not it or it.Ok==false then return end
	if it.Type=="Slider" and not (self._ed and self._ed.Itm==it) then return end
	if it.Left then
		it:Left()
		if it.__rf then it.__rf() end
		self:_snd("Change")
	end
end

function G:DoRight()
	local it = self:_selitm()
	if not it or it.Ok==false then return end
	if it.Type=="Slider" and not (self._ed and self._ed.Itm==it) then return end
	if it.Right then
		it:Right()
		if it.__rf then it.__rf() end
		self:_snd("Change")
	end
end

function G:Select()
	local it = self:_selitm()
	if not it then return end
	if it.Ok==false then
		self:_snd("Error")
		self:Notify("UNSUPPORTED","This feature requires functions your executor doesn't support.",3,"error")
		return
	end
	if it.Type=="Slider" then
		if self._ed and self._ed.Itm==it then self:ConfirmEdit() else self:BeginEdit() end
		return
	end
	self:_snd((it.Type=="Toggle" or it.Type=="List") and "Change" or "Select")
	if it.Activate then
		it:Activate()
		if it.__rf then it.__rf() end
	end
end

function G:Open()
	if self.Opened then return end
	self.Opened = true
	self.Ov.Visible = true
	self.Shad.Visible = true
	self.Mn.Visible = true

	self.Ov.BackgroundTransparency = 1
	tw(self.Ov, TweenInfo.new(0.2,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), {BackgroundTransparency=0.58})

	self.Shad.BackgroundTransparency = 1
	tw(self.Shad, TweenInfo.new(0.2,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), {BackgroundTransparency=0.7})

	local sp = UDim2.new(0, -self.O.Size.X.Offset-20, self.O.FinalPosition.Y.Scale, self.O.FinalPosition.Y.Offset)
	self.Wrap.Position = sp
	tw(self.Wrap, TweenInfo.new(0.35,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), {Position=self.O.FinalPosition})
	self.Shad.Position = offud2(self.O.FinalPosition,4,6)

	self.Sc.Scale = 0.97
	tw(self.Sc, TweenInfo.new(0.2,Enum.EasingStyle.Quart,Enum.EasingDirection.Out), {Scale=1})

	self.Mn.BackgroundTransparency = 0.2
	tw(self.Mn, TweenInfo.new(0.15,Enum.EasingStyle.Linear,Enum.EasingDirection.Out), {BackgroundTransparency=0.06})

	if self._3d then self:Set3D(true) end
	self:_snd("Open")
end

function G:Close()
	if not self.Opened then return end
	if self._ed then self:ConfirmEdit() else self:_stoph() end
	self.Opened = false
	self:_snd("Close")

	local hp = UDim2.new(0, -self.O.Size.X.Offset-20, self.O.FinalPosition.Y.Scale, self.O.FinalPosition.Y.Offset)
	tw(self.Wrap, TweenInfo.new(0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.In), {Position=hp})

	local a = tw(self.Ov, TweenInfo.new(0.2,Enum.EasingStyle.Linear,Enum.EasingDirection.In), {BackgroundTransparency=1})
	tw(self.Shad, TweenInfo.new(0.2,Enum.EasingStyle.Linear,Enum.EasingDirection.In), {BackgroundTransparency=1})
	tw(self.Sc, TweenInfo.new(0.15,Enum.EasingStyle.Linear,Enum.EasingDirection.In), {Scale=0.97})

	if self._3dc then self._3dc:Disconnect(); self._3dc=nil end
	self.Mn.Rotation = 0

	a.Completed:Connect(function()
		if not self.Opened then
			self.Ov.Visible=false
			self.Shad.Visible=false
			self.Mn.Visible=false
		end
	end)
end

function G:Toggle()
	if self.Opened then self:Close() else self:Open() end
end

function G:_binds()
	local o = self.O
	self._cas = {
		"GmmUI_Toggle","GmmUI_Up","GmmUI_Down","GmmUI_Left","GmmUI_Right",
		"GmmUI_PageUp","GmmUI_PageDown","GmmUI_Back","GmmUI_Select"
	}
	for _,nm in ipairs(self._cas) do pcall(function() cas:UnbindAction(nm) end) end

	local pri = (o.InputPriority~=nil and tonumber(o.InputPriority)) or (Enum.ContextActionPriority.High.Value+5000)
	local function bd(n, fn, ...) cas:BindActionAtPriority(n, fn, false, pri, ...) end

	bd("GmmUI_Toggle", function(_,st)
		if st~=Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		self:Toggle()
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.F4, Enum.KeyCode.Insert)

	bd("GmmUI_Up", function(_,st)
		if st~=Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._ed then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelIdx-1)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Up, Enum.KeyCode.KeypadEight, Enum.KeyCode.I)

	bd("GmmUI_Down", function(_,st)
		if st~=Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._ed then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelIdx+1)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Down, Enum.KeyCode.KeypadTwo, Enum.KeyCode.K)

	bd("GmmUI_Left", function(_,st)
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if st==Enum.UserInputState.Begin then
			self:DoLeft(); self:_starth(-1)
			return Enum.ContextActionResult.Sink
		elseif st==Enum.UserInputState.End then
			self:_stoph(-1)
			return Enum.ContextActionResult.Sink
		end
		return Enum.ContextActionResult.Pass
	end, Enum.KeyCode.Left, Enum.KeyCode.KeypadFour, Enum.KeyCode.J)

	bd("GmmUI_Right", function(_,st)
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if st==Enum.UserInputState.Begin then
			self:DoRight(); self:_starth(1)
			return Enum.ContextActionResult.Sink
		elseif st==Enum.UserInputState.End then
			self:_stoph(1)
			return Enum.ContextActionResult.Sink
		end
		return Enum.ContextActionResult.Pass
	end, Enum.KeyCode.Right, Enum.KeyCode.KeypadSix, Enum.KeyCode.L)

	bd("GmmUI_PageUp", function(_,st)
		if st~=Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._ed then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelIdx-10)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.PageUp, Enum.KeyCode.KeypadNine)

	bd("GmmUI_PageDown", function(_,st)
		if st~=Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._ed then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelIdx+10)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.PageDown, Enum.KeyCode.KeypadThree)

	bd("GmmUI_Back", function(_,st)
		if st~=Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._ed then self:CancelEdit() else self:Back() end
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Backspace, Enum.KeyCode.KeypadZero, Enum.KeyCode.U)

	bd("GmmUI_Select", function(_,st)
		if st~=Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		self:Select()
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Return, Enum.KeyCode.KeypadFive, Enum.KeyCode.O)
end

function G:Boot(root, all)
	local scan = Boot.Scan()
	self._scan = scan

	local xn = "Unknown Executor"
	pcall(function()
		local n, v = identifyexecutor()
		if n then xn = tostring(n); if v then xn = xn.." "..tostring(v) end end
	end)
	self:SetSubtitle(xn.."  \226\128\162  "..scan.Nok.."/"..scan.Tot.." UNC")

	if root then root:ApplyBoot(scan) end
	if all then for _,m in ipairs(all) do m:ApplyBoot(scan) end end

	bootNotif(self.Gui, self.O, scan,
		function()
			if root then self:PushMenu(root) end
			task.delay(0.15, function() self:Open() end)
		end,
		function() self:Destroy() end
	)
end

function G:Destroy()
	for _,c in ipairs(self._conn) do pcall(function() c:Disconnect() end) end
	self._conn = {}
	if self._3dc then self._3dc:Disconnect(); self._3dc=nil end
	if self._cas then
		for _,nm in ipairs(self._cas) do pcall(function() cas:UnbindAction(nm) end) end
		self._cas = nil
	end
	if self.SndF then self.SndF:Destroy(); self.SndF=nil end
	if self.Gui then self.Gui:Destroy() end
end

return G
