	})
	if reqs then Boot.RegDep(tostring(lbl), reqs) end
	return itm
end

function M:Toggle(lbl, desc, def, cb, reqs)
	local st = def==true
	local itm = self:_add({
		Type="Toggle",Label=tostring(lbl),Desc=tostring(desc or ""),
		Reqs=reqs,Ok=true,
		Get=function() return st end,
		Set=function(v)
			st = v and true or false
			if typeof(cb)=="function" then task.spawn(cb,st) end
		end,
		Left=function(it) if not it.Ok then return end it.Set(not it.Get()) end,
		Right=function(it) if not it.Ok then return end it.Set(not it.Get()) end,
		Activate=function(it) if not it.Ok then return end it.Set(not it.Get()) end,
		ValueText=function(it)
			if not it.Ok then return "N/A" end
			return it.Get() and "ON" or "OFF"
		end
	})
	if reqs then Boot.RegDep(tostring(lbl), reqs) end
	return itm
end

function M:Slider(lbl, desc, mn, mx, stp, def, cb, reqs)
	mn = tonumber(mn) or 0
	mx = tonumber(mx) or 100
	stp = tonumber(stp) or 1
	local val = math.clamp(tonumber(def) or mn, mn, mx)

	local function sv(v)
		v = math.clamp(v, mn, mx)
		val = math.clamp(mn+(math.floor(((v-mn)/stp)+0.5)*stp), mn, mx)
		if typeof(cb)=="function" then task.spawn(cb, val) end
	end

	local itm = self:_add({
		Type="Slider",Label=tostring(lbl),Desc=tostring(desc or ""),
		Reqs=reqs,Ok=true,
		Get=function() return val end,
		Set=sv,
		Left=function(it) if not it.Ok then return end it.Set(it.Get()-stp) end,
		Right=function(it) if not it.Ok then return end it.Set(it.Get()+stp) end,
		Activate=function() end,
		ValueText=function(it)
			if not it.Ok then return "N/A" end
			return tostring(it.Get())
		end
	})
	if reqs then Boot.RegDep(tostring(lbl), reqs) end
	return itm
end

function M:List(lbl, desc, vals, di, cb, reqs)
	vals = typeof(vals)=="table" and vals or {}
	if #vals==0 then vals={"N/A"} end
	local idx = math.clamp(tonumber(di) or 1, 1, #vals)

	local function si(i)
		idx = ((i-1)%#vals)+1
		if typeof(cb)=="function" then task.spawn(cb, vals[idx], idx) end
	end

	local itm = self:_add({
		Type="List",Label=tostring(lbl),Desc=tostring(desc or ""),
		Reqs=reqs,Ok=true,
		GetIndex=function() return idx end,
		SetIndex=si,
		Left=function(it) if not it.Ok then return end it.SetIndex(it.GetIndex()-1) end,
		Right=function(it) if not it.Ok then return end it.SetIndex(it.GetIndex()+1) end,
		Activate=function(it) if not it.Ok then return end it.SetIndex(it.GetIndex()+1) end,
		ValueText=function() return tostring(vals[idx]) end
	})
	if reqs then Boot.RegDep(tostring(lbl), reqs) end
	return itm
end

function M:Submenu(lbl, desc, sub, reqs)
	assert(getmetatable(sub)==M)
	local itm = self:_add({
		Type="Submenu",Label=tostring(lbl),Desc=tostring(desc or ""),
		HasArrow=true,Reqs=reqs,Ok=true,_subref=sub,
		Activate=function() self.UI:PushMenu(sub) end
	})
	if reqs then Boot.RegDep(tostring(lbl), reqs) end
	return itm
end

function M:ApplyBoot(scan)
	local good, bad = {}, {}
	for _, itm in ipairs(self.Items) do
		local sup = true
		if itm.Reqs then sup = Boot.Chk(itm.Label, scan) end
		itm.Ok = sup
		if sup then good[#good+1]=itm else bad[#bad+1]=itm end
		if itm.Type=="Submenu" and itm._subref then itm._subref:ApplyBoot(scan) end
	end
	self.Items = {}
	for _,x in ipairs(good) do self.Items[#self.Items+1]=x end
	for _,x in ipairs(bad) do self.Items[#self.Items+1]=x end
end

