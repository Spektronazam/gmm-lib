		AutomaticSize=Enum.AutomaticSize.Y,Font=Enum.Font.ArialBold,
		Text=title,TextColor3=self.O.Text,TextTransparency=1,TextSize=14,
		TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top
	})

	local bd = mk("TextLabel",{
		Parent=ct,BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),
		AutomaticSize=Enum.AutomaticSize.Y,Font=Enum.Font.Arial,
		Text=text,TextColor3=self.O.Text,TextTransparency=1,TextSize=13,
		TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top
	})

	local lb = mk("Frame",{
		Parent=note,AnchorPoint=Vector2.new(0,1),Position=UDim2.new(0,0,1,0),
		Size=UDim2.new(1,0,0,3),BackgroundColor3=Color3.fromRGB(55,55,55),
		BackgroundTransparency=1,BorderSizePixel=0
	})
	local lf = mk("Frame",{Parent=lb,Size=UDim2.new(1,0,1,0),BackgroundColor3=ac,BackgroundTransparency=1,BorderSizePixel=0})

	local nd = {Fr=note,Str=nstr,Tl=tl,Ti=ti,Bd=bd,Cl=cl,Ab=ab,Lb=lb,Lf=lf,Kind=kind}
	self._nots[#self._nots+1] = nd

	local shut = false
	local function die()
		if shut then return end
		shut = true
		local xi = TweenInfo.new(0.15,Enum.EasingStyle.Quart,Enum.EasingDirection.In)
		tw(note,xi,{BackgroundTransparency=1})
		tw(nstr,xi,{Transparency=1})
		tw(tl,xi,{BackgroundTransparency=1})
		tw(ab,xi,{BackgroundTransparency=1})
		tw(ti,xi,{TextTransparency=1})
		tw(bd,xi,{TextTransparency=1})
		tw(cl,xi,{TextTransparency=1})
		tw(lb,xi,{BackgroundTransparency=1})
		tw(lf,xi,{BackgroundTransparency=1})
		task.delay(0.17,function()
			for j=#self._nots,1,-1 do
				if self._nots[j]==nd then table.remove(self._nots,j); break end
			end
			if note then note:Destroy() end
		end)
	end

	cl.MouseEnter:Connect(function() cl.TextColor3=self.O.Text end)
	cl.MouseLeave:Connect(function() cl.TextColor3=self.O.MutedText end)
	cl.MouseButton1Click:Connect(die)

	note.Position = UDim2.new(-1,0,0,0)
	local ei = TweenInfo.new(0.25,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
	tw(note,ei,{Position=UDim2.new(0,0,0,0),BackgroundTransparency=0.08})
	tw(nstr,ei,{Transparency=0.3})
	tw(tl,ei,{BackgroundTransparency=0})
	tw(ab,ei,{BackgroundTransparency=0})
	tw(ti,ei,{TextTransparency=0})
	tw(bd,ei,{TextTransparency=0})
	tw(cl,ei,{TextTransparency=0})
	tw(lb,ei,{BackgroundTransparency=0})
	tw(lf,ei,{BackgroundTransparency=0})
	tw(lf, TweenInfo.new(dur,Enum.EasingStyle.Linear,Enum.EasingDirection.Out), {Size=UDim2.new(0,0,1,0)})

	self:_snd(string.lower(tostring(kind))=="error" and "Error" or "Notify")
	task.delay(dur, die)
	return die
end

