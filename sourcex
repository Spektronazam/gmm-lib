local function derive(o)
	o.Select = o.Select or Color3.fromRGB(242,242,242)
	o.Panel = o.Panel or Color3.fromRGB(7,7,7)
	o.Panel2 = o.Panel2 or Color3.fromRGB(18,18,18)
	o.Row = o.Row or Color3.fromRGB(28,28,28)
	o.RowHover = o.RowHover or Color3.fromRGB(42,42,42)
	o.RowSelected = o.RowSelected or o.Select
	o.Pill = o.Pill or Color3.fromRGB(20,20,20)
	o.Stroke = o.Stroke or Color3.fromRGB(70,70,70)
	o.MutedText = o.MutedText or Color3.fromRGB(185,185,185)
	o.HeaderAccent2 = o.HeaderAccent2 or sshift(o.Accent, 0.12)
end

local function buildopts(uo)
	local raw = dupe(uo or {})
	local base = dupe(DEF)
	local th = raw.Theme
	raw.Theme = nil
	if typeof(th)=="string" and THEMES[th] then
		patch(base, THEMES[th])
	elseif typeof(th)=="table" then
		patch(base, th)
	end
	patch(base, raw)
	base.Theme = typeof(th)=="string" and th or (typeof(th)=="table" and "Custom" or base.Theme)
	derive(base)
	return base
end

