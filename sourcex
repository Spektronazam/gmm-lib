local function mk(c, p)
	local i = Instance.new(c)
	for k, v in pairs(p or {}) do i[k] = v end
	return i
end

local function tw(o, ti, p)
	local t = ts:Create(o, ti, p)
	t:Play()
	return t
end

local function lerpc3(a, b, t)
	return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end
local function lit(c, a) return lerpc3(c, Color3.new(1,1,1), a) end
local function dim(c, a) return lerpc3(c, Color3.new(0,0,0), a) end

local function sshift(c, a)
	if (0.2126*c.R)+(0.7152*c.G)+(0.0722*c.B) > 0.6 then return dim(c,a) end
	return lit(c,a)
end

local function dupe(t)
	local r = {}
	for k,v in pairs(t or {}) do
		if typeof(v)=="table" then
			local x = {}
			for ik,iv in pairs(v) do x[ik]=iv end
			r[k]=x
		else r[k]=v end
	end
	return r
end

local function patch(dst, src)
	for k,v in pairs(src or {}) do
		if typeof(v)=="table" and typeof(dst[k])=="table" then
			for ik,iv in pairs(v) do dst[k][ik]=iv end
		else dst[k]=v end
	end
	return dst
end

local function corner(o, r) return mk("UICorner",{Parent=o,CornerRadius=UDim.new(0,math.max(0,tonumber(r)or 0))}) end
local function stroke(o, c, tr, th) return mk("UIStroke",{Parent=o,ApplyStrokeMode=Enum.ApplyStrokeMode.Border,Color=c,Transparency=tr or 0,Thickness=th or 1}) end
local function pad(o, l, r, t, b) return mk("UIPadding",{Parent=o,PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0)}) end

local function offud2(p, x, y)
	return UDim2.new(p.X.Scale, p.X.Offset+(x or 0), p.Y.Scale, p.Y.Offset+(y or 0))
end

