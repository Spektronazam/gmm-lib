local function guiParent()
	local lp = plrs.LocalPlayer
	return (lp and lp:FindFirstChildOfClass("PlayerGui")) or game:GetService("CoreGui")
end

local Sig = {}; Sig.__index = Sig
function Sig.new() return setmetatable({_fn = {}}, Sig) end
function Sig:Connect(fn)
	local c = {fn = fn, on = true}
	function c:Disconnect() c.on = false end
	self._fn[#self._fn + 1] = c; return c
end
function Sig:Fire(...)
	for i = #self._fn, 1, -1 do
		if self._fn[i].on then task.spawn(self._fn[i].fn, ...)
		else table.remove(self._fn, i) end
	end
end

