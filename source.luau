local Menu = {}; Menu.__index = Menu

function Menu.new(ui, name)
	return setmetatable({
		UI = ui, Name = tostring(name or "MENU"):upper(),
		Items = {}, OnEnter = Sig.new(), OnExit = Sig.new(),
	}, Menu)
end

function Menu:_push(item)
	item._menu = self
	self.Items[#self.Items + 1] = item
	if self.UI and self.UI.Current == self then self.UI:_renderMenu(self) end
	return item
end

function Menu:RemoveItem(item)
	for i, v in ipairs(self.Items) do
		if v == item then
			table.remove(self.Items, i)
			if v.__row then pcall(v.__row.Destroy, v.__row) end
			break
		end
	end
	if self.UI and self.UI.Current == self then self.UI:_renderMenu(self) end
end

function Menu:ClearItems()
	for _, v in ipairs(self.Items) do
		if v.__row then pcall(v.__row.Destroy, v.__row) end
	end
	self.Items = {}
	if self.UI and self.UI.Current == self then self.UI:_renderMenu(self) end
end

function Menu:Button(lbl, desc, cb)
	return self:_push({
		Type = "Button", Label = tostring(lbl), Desc = tostring(desc or ""),
		Activate = function() if typeof(cb) == "function" then task.spawn(cb) end end,
	})
end

function Menu:Toggle(lbl, desc, def, cb)
	local st = def == true
	local itm; itm = {
		Type = "Toggle", Label = tostring(lbl), Desc = tostring(desc or ""),
		Get = function() return st end,
		Set = function(v) st = v and true or false; if typeof(cb) == "function" then task.spawn(cb, st) end end,
		Left = function(s) s.Set(not s.Get()) end,
		Right = function(s) s.Set(not s.Get()) end,
		Activate = function(s) s.Set(not s.Get()) end,
		ValueText = function(s) return s.Get() and "ON" or "OFF" end,
	}
	return self:_push(itm)
end

function Menu:Slider(lbl, desc, lo, hi, stp, def, cb)
	lo = tonumber(lo) or 0; hi = tonumber(hi) or 100; stp = tonumber(stp) or 1
	local val = math.clamp(tonumber(def) or lo, lo, hi)
	local function _set(v)
		v = math.clamp(v, lo, hi)
		val = math.clamp(lo + math.floor((v - lo) / stp + 0.5) * stp, lo, hi)
		if typeof(cb) == "function" then task.spawn(cb, val) end
	end
	return self:_push({
		Type = "Slider", Label = tostring(lbl), Desc = tostring(desc or ""),
		Get = function() return val end, Set = _set,
		Left = function(s) s.Set(s.Get() - stp) end,
		Right = function(s) s.Set(s.Get() + stp) end,
		Activate = function() end,
		ValueText = function(s) return tostring(s.Get()) end,
		_lo = lo, _hi = hi, _stp = stp,
	})
end

function Menu:List(lbl, desc, vals, defIdx, cb)
	vals = (typeof(vals) == "table" and vals) or {}
	if #vals == 0 then vals = {"N/A"} end
	local idx = math.clamp(tonumber(defIdx) or 1, 1, #vals)
	local function _si(i)
		idx = ((i - 1) % #vals) + 1
		if typeof(cb) == "function" then task.spawn(cb, vals[idx], idx) end
	end
	return self:_push({
		Type = "List", Label = tostring(lbl), Desc = tostring(desc or ""),
		GetIndex = function() return idx end, SetIndex = _si,
		Left = function(s) s.SetIndex(s.GetIndex() - 1) end,
		Right = function(s) s.SetIndex(s.GetIndex() + 1) end,
		Activate = function(s) s.SetIndex(s.GetIndex() + 1) end,
		ValueText = function() return tostring(vals[idx]) end,
	})
end

function Menu:Submenu(lbl, desc, sub)
	assert(getmetatable(sub) == Menu, "expected Menu")
	return self:_push({
		Type = "Submenu", Label = tostring(lbl), Desc = tostring(desc or ""),
		HasArrow = true,
		Activate = function() self.UI:PushMenu(sub) end,
	})
end

function Menu:Separator(lbl)
	return self:_push({ Type = "Separator", Label = tostring(lbl or ""), Desc = "", Selectable = false })
end

function Menu:Keybind(lbl, desc, defKey, cb)
	local key = defKey or Enum.KeyCode.Unknown
	local listening = false
	return self:_push({
		Type = "Keybind", Label = tostring(lbl), Desc = tostring(desc or "Press Enter to rebind"),
		Get = function() return key end, Set = function(v) key = v end,
		IsListening = function() return listening end,
		Activate = function(s)
			if listening then return end
			listening = true
			if s.__refreshValue then s.__refreshValue() end
			local cn; cn = uis.InputBegan:Connect(function(inp)
				if inp.UserInputType ~= Enum.UserInputType.Keyboard then return end
				listening = false
				if inp.KeyCode ~= Enum.KeyCode.Escape then
					key = inp.KeyCode
					if typeof(cb) == "function" then task.spawn(cb, key) end
				end
				if s.__refreshValue then s.__refreshValue() end
				if cn then cn:Disconnect() end
			end)
			task.delay(5, function()
				if not listening then return end
				listening = false
				if s.__refreshValue then s.__refreshValue() end
				if cn then cn:Disconnect() end
			end)
		end,
		ValueText = function()
			if listening then return "[ ... ]" end
			return key == Enum.KeyCode.Unknown and "NONE" or key.Name
		end,
	})
end

function Menu:ColorPicker(lbl, desc, defClr, cb)
	local pal = {
		Color3.fromRGB(255,255,255), Color3.fromRGB(200,200,200),
		Color3.fromRGB(138,3,3), Color3.fromRGB(220,40,40),
		Color3.fromRGB(255,100,50), Color3.fromRGB(255,180,0),
		Color3.fromRGB(255,255,0), Color3.fromRGB(100,220,0),
		Color3.fromRGB(0,180,80), Color3.fromRGB(0,180,180),
		Color3.fromRGB(0,120,255), Color3.fromRGB(60,60,220),
		Color3.fromRGB(140,40,220), Color3.fromRGB(220,0,180),
		Color3.fromRGB(255,100,200), Color3.fromRGB(0,0,0),
	}
	local idx = 1
	if defClr then
		local best, bd = 1, math.huge
		for i, c in ipairs(pal) do
			local d = (c.R - defClr.R)^2 + (c.G - defClr.G)^2 + (c.B - defClr.B)^2
			if d < bd then best, bd = i, d end
		end
		idx = best
	end
	local function _fire()
		if typeof(cb) == "function" then task.spawn(cb, pal[idx]) end
	end
	return self:_push({
		Type = "ColorPicker", Label = tostring(lbl), Desc = tostring(desc or "Use ◄ ► to pick"),
		Get = function() return pal[idx] end, GetIndex = function() return idx end,
		Left = function() idx = ((idx - 2) % #pal) + 1; _fire() end,
		Right = function() idx = (idx % #pal) + 1; _fire() end,
		Activate = function() idx = (idx % #pal) + 1; _fire() end,
		ValueText = function()
			local c = pal[idx]
			return string.format("#%02X%02X%02X", math.floor(c.R * 255), math.floor(c.G * 255), math.floor(c.B * 255))
		end,
		_pal = pal,
	})
end

