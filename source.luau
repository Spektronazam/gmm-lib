	local o = self.Opts
	local row = mk("Frame", {
		Parent = self.Scroll, Size = UDim2.new(1, 0, 0, item.Label ~= "" and 22 or 10),
		BackgroundTransparency = 1, BorderSizePixel = 0,
	})
	if item.Label ~= "" then
		mk("TextLabel", {
			Parent = row, BackgroundTransparency = 1, Position = UDim2.fromOffset(12, 0),
			Size = UDim2.new(1, -24, 1, 0), Font = Enum.Font.GothamBold,
			Text = item.Label:upper(), TextColor3 = o.DimText, TextSize = 10,
			TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Bottom,
		})
	end
	mk("Frame", {
		Parent = row, AnchorPoint = Vector2.new(0, 1), Position = UDim2.new(0, 12, 1, -1),
		Size = UDim2.new(1, -24, 0, 1), BackgroundColor3 = o.Divider,
		BackgroundTransparency = 0.4, BorderSizePixel = 0,
	})
	return row
end

function GmmUI:_makeRow(item, idx)
	if item.Type == "Separator" then
		return self:_makeSeparator(item), nil, nil, nil
	end

	local o = self.Opts
	local rh = o.RowHeight
	local row = mk("TextButton", {
		Parent = self.Scroll, Size = UDim2.new(1, 0, 0, rh),
		BackgroundTransparency = 1, BorderSizePixel = 0, AutoButtonColor = false, Text = "",
	})
	local selBg = mk("Frame", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = o.Select, BackgroundTransparency = 1, BorderSizePixel = 0})
	local hovBg = mk("Frame", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = o.HoverBg, BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 0})
	local bar = mk("Frame", {Parent = row, Size = UDim2.new(0, o.AccentBarWidth, 1, 0), BackgroundColor3 = o.Accent, BorderSizePixel = 0, Visible = false})
	mk("Frame", {
		Parent = row, AnchorPoint = Vector2.new(0, 1), Position = UDim2.new(0, 12, 1, 0),
		Size = UDim2.new(1, -24, 0, 1), BackgroundColor3 = o.Divider,
		BackgroundTransparency = 0.75, BorderSizePixel = 0,
	})

	local lbl = mk("TextLabel", {
		Parent = row, BackgroundTransparency = 1,
		Position = UDim2.fromOffset(14 + o.AccentBarWidth, 0),
		Size = UDim2.new(1, -130, 1, 0), Font = Enum.Font.Gotham,
		Text = item.Label, TextColor3 = o.Text, TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd,
	})
	local rLbl = mk("TextLabel", {
		Parent = row, BackgroundTransparency = 1,
		Position = UDim2.new(1, -110, 0, 0), Size = UDim2.fromOffset(80, rh),
		Font = Enum.Font.GothamBold, Text = "", TextColor3 = o.Text, TextSize = 13,
		TextXAlignment = Enum.TextXAlignment.Right,
	})
	local arrow = mk("TextLabel", {
		Parent = row, BackgroundTransparency = 1, Position = UDim2.new(1, -24, 0, 0),
		Size = UDim2.fromOffset(20, rh), Font = Enum.Font.GothamBold, Text = "►",
		TextColor3 = o.Text, TextSize = 11,
		Visible = (item.HasArrow or item.Type == "Submenu"),
	})

	local togBg, togDot
	if item.Type == "Toggle" then
		togBg = mk("Frame", {
			Parent = row, AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(1, -42, 0.5, 0), Size = UDim2.fromOffset(28, 14),
			BackgroundColor3 = Color3.fromRGB(60, 60, 60), BorderSizePixel = 0,
		})
		mk("UICorner", {CornerRadius = UDim.new(1, 0), Parent = togBg})
		togDot = mk("Frame", {
			Parent = togBg, AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(0, 2, 0.5, 0), Size = UDim2.fromOffset(10, 10),
			BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0,
		})
		mk("UICorner", {CornerRadius = UDim.new(1, 0), Parent = togDot})
		rLbl.Position = UDim2.new(1, -76, 0, 0); rLbl.Size = UDim2.fromOffset(30, rh)
	end

	local slBg, slFill
	if item.Type == "Slider" then
		slBg = mk("Frame", {
			Parent = row, AnchorPoint = Vector2.new(0.5, 1),
			Position = UDim2.new(0.5, 0, 1, -2), Size = UDim2.new(1, -28, 0, 3),
			BackgroundColor3 = o.Divider, BackgroundTransparency = 0.5,
			BorderSizePixel = 0, Visible = false, ClipsDescendants = true,
		})
		mk("UICorner", {CornerRadius = UDim.new(0, 2), Parent = slBg})
		slFill = mk("Frame", {Parent = slBg, Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = o.Accent, BorderSizePixel = 0})
		mk("UICorner", {CornerRadius = UDim.new(0, 2), Parent = slFill})
	end

	local lArr, rArr
	if item.Type == "List" then
		lArr = mk("TextLabel", {
			Parent = row, BackgroundTransparency = 1, Position = UDim2.new(1, -120, 0, 0),
			Size = UDim2.fromOffset(14, rh), Font = Enum.Font.GothamBold, Text = "◄",
			TextColor3 = o.Accent, TextSize = 11, Visible = false,
		})
		rArr = mk("TextLabel", {
			Parent = row, BackgroundTransparency = 1, Position = UDim2.new(1, -26, 0, 0),
			Size = UDim2.fromOffset(14, rh), Font = Enum.Font.GothamBold, Text = "►",
			TextColor3 = o.Accent, TextSize = 11, Visible = false,
		})
		rLbl.Position = UDim2.new(1, -106, 0, 0); rLbl.Size = UDim2.fromOffset(80, rh)
	end

	local colSw
	if item.Type == "ColorPicker" then
		colSw = mk("Frame", {
			Parent = row, AnchorPoint = Vector2.new(0, 0.5),
			Position = UDim2.new(1, -28, 0.5, 0), Size = UDim2.fromOffset(14, 14),
			BackgroundColor3 = item.Get and item:Get() or Color3.new(1, 1, 1), BorderSizePixel = 0,
		})
		mk("UICorner", {CornerRadius = UDim.new(0, 3), Parent = colSw})
		mk("UIStroke", {Parent = colSw, Color = Color3.new(1, 1, 1), Thickness = 1, Transparency = 0.5})
		rLbl.Position = UDim2.new(1, -130, 0, 0); rLbl.Size = UDim2.fromOffset(80, rh)
	end

	local picked = false

	local function _syncTog()
		if not (togBg and togDot and item.Get) then return end
		local on = item.Get()
		tw(togBg, TweenInfo.new(0.15), {BackgroundColor3 = on and o.Accent or Color3.fromRGB(60, 60, 60)})
		tw(togDot, TweenInfo.new(0.15), {Position = on and UDim2.new(1, -12, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)})
	end

	local function setSel(on)
		picked = on; bar.Visible = on
		if on then
			selBg.BackgroundTransparency = 0.15
			tw(selBg, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0.05})
		else
			selBg.BackgroundTransparency = 1
		end
		local tc = on and o.SelectedText or o.Text
		lbl.TextColor3 = tc; rLbl.TextColor3 = tc; arrow.TextColor3 = tc
		lbl.Font = on and Enum.Font.GothamMedium or Enum.Font.Gotham
		if lArr then lArr.Visible = on; rArr.Visible = on end
		_syncTog()
	end

	local function setHov(on)
		if picked then return end
		tw(hovBg, TweenInfo.new(on and 0.1 or 0.12), {BackgroundTransparency = on and 0.3 or 1})
	end

	local function refresh()
		if item.ValueText then
			local tx = item:ValueText()
			if item.Type == "Slider" and self._edit and self._edit.Item == item then
				rLbl.Text = "◄ " .. tx .. " ►"
				if slBg then slBg.Visible = true end
			else
				rLbl.Text = tx
				if slBg and not (self._edit and self._edit.Item == item) then slBg.Visible = false end
			end
		else
			rLbl.Text = ""
		end
		if slFill and item.Get and item._lo ~= nil then
			local pct = math.clamp((item.Get() - item._lo) / math.max(item._hi - item._lo, 0.001), 0, 1)
			tw(slFill, TweenInfo.new(0.08), {Size = UDim2.new(pct, 0, 1, 0)})
		end
		_syncTog()
		if colSw and item.Get then
			local c = item:Get()
			if typeof(c) == "Color3" then tw(colSw, TweenInfo.new(0.1), {BackgroundColor3 = c}) end
		end
	end

	refresh()
	row.MouseButton1Click:Connect(function()
		if self._edit then return end
		if self.SelectedIndex == idx then self:Select(); self:_sfx("Sel")
		else self:SetSelected(idx); self:_sfx("Nav") end
	end)

	return row, setSel, refresh, setHov
end

function GmmUI:_renderMenu(menu)
	self:_clearRows()
	self.Current = menu
	self:SetTab(menu.Name)
	for i, item in ipairs(menu.Items) do
		local row, sel, ref, hov = self:_makeRow(item, i)
		item.__row = row; item.__setSelected = sel; item.__refreshValue = ref
		self._rows[#self._rows + 1] = row
		self._rmeta[i] = {sel = sel, ref = ref, hov = hov}
	end
	if #menu.Items > 0 then
		local sy = tonumber(menu._sy) or 0
		if self._scrollTw then pcall(self._scrollTw.Cancel, self._scrollTw); self._scrollTw = nil end
		self.Scroll.CanvasPosition = Vector2.new(0, sy)
		self._scrollTgtY = sy
		local si = tonumber(menu._si)
		if not (si and si >= 1 and si <= #menu.Items) then
			si = 1
			for j, it in ipairs(menu.Items) do
				if it.Selectable ~= false then si = j; break end
			end
		end
		self:SetSelected(si)
	else
		self.SelectedIndex = 0; self.DescLabel.Text = "No options."; self:_updateCounter()
	end
end

function GmmUI:PushMenu(menu)
	self:_saveState()
	self.MenuStack[#self.MenuStack + 1] = menu
	menu.OnEnter:Fire()
	if self.Opts.AnimateMenuSwitch and self.Opened then
		local sc = self.Scroll; local op = sc.Position
		tw(sc, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = op + UDim2.fromOffset(-20, 0)})
		task.wait(0.08); self:_renderMenu(menu)
		sc.Position = op + UDim2.fromOffset(20, 0)
		tw(sc, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = op})
	else
		self:_renderMenu(menu)
	end
	if not self.Opened then self:Open() end
end

function GmmUI:Back()
	if self._edit then self:CancelEdit(); return end
	if #self.MenuStack <= 1 then self:Close(); return end
	self:_saveState()
	local leaving = table.remove(self.MenuStack)
	if leaving then leaving.OnExit:Fire() end
	local top = self.MenuStack[#self.MenuStack]
	if self.Opts.AnimateMenuSwitch and self.Opened then
		local sc = self.Scroll; local op = sc.Position
		tw(sc, TweenInfo.new(0.08, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = op + UDim2.fromOffset(20, 0)})
		task.wait(0.08); self:_renderMenu(top)
		sc.Position = op + UDim2.fromOffset(-20, 0)
		tw(sc, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = op})
	else
		self:_renderMenu(top)
	end
end

function GmmUI:_scrollTo(ty)
	local sc = self.Scroll; if not sc then return end
	ty = tonumber(ty) or 0; self._scrollTgtY = ty
	local mx = math.max(0, sc.AbsoluteCanvasSize.Y - sc.AbsoluteSize.Y)
	ty = math.clamp(ty, 0, mx)
	if self._scrollTw then pcall(self._scrollTw.Cancel, self._scrollTw); self._scrollTw = nil end
	local sm = tonumber(self.Opts.ScrollSmoothness) or 0
	if sm <= 0 then sc.CanvasPosition = Vector2.new(0, ty); self._scrollTgtY = ty; return end
	self._scrollTw = tw(sc, TweenInfo.new(math.clamp(0.04 * sm, 0.05, 0.4), Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CanvasPosition = Vector2.new(0, ty)})
end

function GmmUI:SetSelected(idx)
	if not self.Current then return end
	local items = self.Current.Items
	if #items == 0 then return end
	idx = ((idx - 1) % #items) + 1
	local start = idx
	while items[idx] and items[idx].Selectable == false do
		idx = (idx % #items) + 1
		if idx == start then break end
	end
	if items[idx] and items[idx].Selectable == false then return end
	if self._hovIdx == self.SelectedIndex then
		local m = self._rmeta[self._hovIdx]
		if m and m.hov then m.hov(false) end
	end
	self.SelectedIndex = idx
	for i, it in ipairs(items) do
		if it.__setSelected then it.__setSelected(i == idx) end
	end
	local it = items[idx]
	self.DescLabel.Text = (it and it.Desc and it.Desc ~= "" and it.Desc) or "Select an option."
	self:_updateCounter()
	if it and it.__row then
		local ry = it.__row.AbsolutePosition.Y
		local rh = it.__row.AbsoluteSize.Y
		local sTop = self.Scroll.AbsolutePosition.Y
		local sBot = sTop + self.Scroll.AbsoluteSize.Y
		if ry < sTop then self:_scrollTo(self.Scroll.CanvasPosition.Y - (sTop - ry))
		elseif (ry + rh) > sBot then self:_scrollTo(self.Scroll.CanvasPosition.Y + ((ry + rh) - sBot)) end
	end
	self:_saveState(); self.OnSelect:Fire(it, idx)
end

function GmmUI:_cur()
	if not self.Current then return nil end
	return self.Current.Items[self.SelectedIndex]
end

function GmmUI:_stopHold(dir)
	if dir == nil or self._holdDir == dir then
		self._holdDir = nil; self._holdTk = (self._holdTk or 0) + 1
	end
end

function GmmUI:_startHold(dir)
	local it = self._edit and self._edit.Item
	if not (self.Opened and it and it == self:_cur() and it.Type == "Slider") then return end
	self._holdDir = dir; self._holdTk = (self._holdTk or 0) + 1
	local tk = self._holdTk
	task.spawn(function()
		task.wait(0.32)
		while self._holdTk == tk and self._holdDir == dir do
			if not self.Opened or not self._edit or self._edit.Item ~= it then break end
			if dir < 0 then self:DoLeft() else self:DoRight() end
			task.wait(0.04)
		end
	end)
end

function GmmUI:BeginEdit()
	if self._edit then return end
	local it = self:_cur()
	if not it or it.Type ~= "Slider" then return end
	self._edit = {Item = it, Orig = it.Get and it.Get() or nil}
	if it.__refreshValue then it.__refreshValue() end
end

function GmmUI:ConfirmEdit()
	if not self._edit then return end
	local it = self._edit.Item; self._edit = nil; self:_stopHold()
	if it and it.__refreshValue then it.__refreshValue() end
end

function GmmUI:CancelEdit()
	if not self._edit then return end
	local it, orig = self._edit.Item, self._edit.Orig
	self._edit = nil; self:_stopHold()
	if it and orig ~= nil and it.Set then it.Set(orig) end
	if it and it.__refreshValue then it.__refreshValue() end
end

function GmmUI:DoLeft()
	local it = self:_cur(); if not it then return end
	if it.Type == "Slider" and not (self._edit and self._edit.Item == it) then return end
	if it.Left then it:Left(); if it.__refreshValue then it.__refreshValue() end; self:_sfx("Nav") end
end

function GmmUI:DoRight()
	local it = self:_cur(); if not it then return end
	if it.Type == "Slider" and not (self._edit and self._edit.Item == it) then return end
	if it.Right then it:Right(); if it.__refreshValue then it.__refreshValue() end; self:_sfx("Nav") end
end

function GmmUI:Select()
	local it = self:_cur(); if not it then return end
	if it.Type == "Slider" then
		if self._edit and self._edit.Item == it then self:ConfirmEdit() else self:BeginEdit() end
		return
	end
	if it.Activate then it:Activate(); if it.__refreshValue then it.__refreshValue() end end
end

function GmmUI:Open()
	if self.Opened then return end
	self.Opened = true; self.Main.Visible = true
	if self._shadow then self._shadow.Visible = true end
	self.Main.Size = self.Opts.Size - UDim2.fromOffset(10, 10)
	self.Main.BackgroundTransparency = 0.3
	tw(self.Main, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = self.Opts.Size, BackgroundTransparency = 0.05,
	})
	if self._shadow then
		self._shadow.ImageTransparency = 1
		tw(self._shadow, TweenInfo.new(0.2), {ImageTransparency = 0.4})
	end
	self:_sfx("Open"); self.OnOpen:Fire()
end

function GmmUI:Close()
	if not self.Opened then return end
	if self._edit then self:ConfirmEdit() else self:_stopHold() end
	self.Opened = false
	local t = tw(self.Main, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = self.Opts.Size - UDim2.fromOffset(10, 10), BackgroundTransparency = 0.4,
	})
	if self._shadow then tw(self._shadow, TweenInfo.new(0.14), {ImageTransparency = 1}) end
	t.Completed:Connect(function()
		if not self.Opened then
			self.Main.Visible = false
			if self._shadow then self._shadow.Visible = false end
		end
	end)
	self:_sfx("Close"); self.OnClose:Fire()
end

function GmmUI:Toggle()
	if self.Opened then self:Close() else self:Open() end
end

function GmmUI:Destroy()
	for _, c in ipairs(self._conns) do pcall(c.Disconnect, c) end
	self._conns = {}
	if self._casNames then
		for _, n in ipairs(self._casNames) do pcall(cas.UnbindAction, cas, n) end
		self._casNames = nil
	end
	if self.Gui then self.Gui:Destroy() end
end

return GmmUI
