function GmmUI:_hookInput()
	local prio = (self.Opts.InputPriority and tonumber(self.Opts.InputPriority)) or (Enum.ContextActionPriority.High.Value + 5000)
	self._casNames = {}

	local function reg(name, fn, ...)
		self._casNames[#self._casNames + 1] = name
		pcall(cas.UnbindAction, cas, name)
		cas:BindActionAtPriority(name, fn, false, prio, ...)
	end

	reg("Gmm_Tog", function(_, s)
		if s ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		self:Toggle(); return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.F4, Enum.KeyCode.Insert)

	reg("Gmm_Up", function(_, s)
		if s ~= Enum.UserInputState.Begin or not self.Opened or self._edit then return Enum.ContextActionResult.Pass end
		self:SetSelected(self.SelectedIndex - 1); self:_sfx("Nav"); return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Up, Enum.KeyCode.KeypadEight, Enum.KeyCode.I)

	reg("Gmm_Dn", function(_, s)
		if s ~= Enum.UserInputState.Begin or not self.Opened or self._edit then return Enum.ContextActionResult.Pass end
		self:SetSelected(self.SelectedIndex + 1); self:_sfx("Nav"); return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Down, Enum.KeyCode.KeypadTwo, Enum.KeyCode.K)

	reg("Gmm_Lt", function(_, s)
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if s == Enum.UserInputState.Begin then
			self:DoLeft(); self:_startHold(-1); return Enum.ContextActionResult.Sink
		elseif s == Enum.UserInputState.End then
			self:_stopHold(-1); return Enum.ContextActionResult.Sink
		end
		return Enum.ContextActionResult.Pass
	end, Enum.KeyCode.Left, Enum.KeyCode.KeypadFour, Enum.KeyCode.J)

	reg("Gmm_Rt", function(_, s)
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if s == Enum.UserInputState.Begin then
			self:DoRight(); self:_startHold(1); return Enum.ContextActionResult.Sink
		elseif s == Enum.UserInputState.End then
			self:_stopHold(1); return Enum.ContextActionResult.Sink
		end
		return Enum.ContextActionResult.Pass
	end, Enum.KeyCode.Right, Enum.KeyCode.KeypadSix, Enum.KeyCode.L)

	reg("Gmm_PgU", function(_, s)
		if s ~= Enum.UserInputState.Begin or not self.Opened or self._edit then return Enum.ContextActionResult.Pass end
		self:SetSelected(self.SelectedIndex - 10); self:_sfx("Nav"); return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.PageUp, Enum.KeyCode.KeypadNine)

	reg("Gmm_PgD", function(_, s)
		if s ~= Enum.UserInputState.Begin or not self.Opened or self._edit then return Enum.ContextActionResult.Pass end
		self:SetSelected(self.SelectedIndex + 10); self:_sfx("Nav"); return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.PageDown, Enum.KeyCode.KeypadThree)

	reg("Gmm_Bk", function(_, s)
		if s ~= Enum.UserInputState.Begin or not self.Opened then return Enum.ContextActionResult.Pass end
		if self._edit then self:CancelEdit() else self:Back() end
		self:_sfx("Back"); return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Backspace, Enum.KeyCode.KeypadZero, Enum.KeyCode.U)

	reg("Gmm_Sel", function(_, s)
		if s ~= Enum.UserInputState.Begin or not self.Opened then return Enum.ContextActionResult.Pass end
		self:Select(); self:_sfx("Sel"); return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Return, Enum.KeyCode.KeypadFive, Enum.KeyCode.O)

	self._conns[#self._conns + 1] = uis.InputChanged:Connect(function(inp)
		if not self.Opened or inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
		self:_doHover(inp.Position)
	end)

	self._conns[#self._conns + 1] = uis.InputBegan:Connect(function(inp)
		if not self.Opened or self._edit or inp.UserInputType ~= Enum.UserInputType.MouseWheel then return end
		self:SetSelected(self.SelectedIndex - math.sign(inp.Position.Z)); self:_sfx("Nav")
	end)
end

function GmmUI.new(opts)
	opts = opts or {}
	local theme = THEMES[opts.Theme or "Default"] or THEMES.Default
	for k, v in pairs(DEFS) do if opts[k] == nil then opts[k] = theme[k] or v end end
	for k, v in pairs(theme) do if opts[k] == nil then opts[k] = v end end

	local self = setmetatable({}, GmmUI)
	self.Opts = opts
	self.Opened = false
	self.MenuStack = {}
	self.Current = nil
	self.SelectedIndex = 0
	self._conns = {}
	self._rows = {}
	self._rmeta = {}
	self._edit = nil
	self._holdDir = nil
	self._holdTk = 0
	self._hovIdx = 0
	self.OnOpen = Sig.new()
	self.OnClose = Sig.new()
	self.OnSelect = Sig.new()

	self:_buildShell()
	self:_buildHeader()
	self:_buildSubHeader()
	self:_buildScroll()
	self:_buildFooter()
	self:_buildNotifs()
	self:_hookInput()

	self.Main.Visible = false
	if self._shadow then self._shadow.Visible = false end
	return self
end

function GmmUI:_doHover(pos)
	if not self.Current then return end
	for i, it in ipairs(self.Current.Items) do
		if it.__row and it.Selectable ~= false then
			local ap, az = it.__row.AbsolutePosition, it.__row.AbsoluteSize
			if pos.X >= ap.X and pos.X <= ap.X + az.X and pos.Y >= ap.Y and pos.Y <= ap.Y + az.Y then
				if self._hovIdx ~= i then
					if self._hovIdx > 0 and self._hovIdx ~= self.SelectedIndex then
						local m = self._rmeta[self._hovIdx]
						if m and m.hov then m.hov(false) end
					end
					self._hovIdx = i
					if i ~= self.SelectedIndex then
						local m = self._rmeta[i]
						if m and m.hov then m.hov(true) end
					end
				end
				return
			end
		end
	end
	if self._hovIdx > 0 and self._hovIdx ~= self.SelectedIndex then
		local m = self._rmeta[self._hovIdx]
		if m and m.hov then m.hov(false) end
	end
	self._hovIdx = 0
end

function GmmUI:Notify(title, msg, dur)
	dur = tonumber(dur) or 4
	local o = self.Opts
	local card = mk("Frame", {
		Parent = self._notifBox, Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = o.Bg,
		BackgroundTransparency = 1, BorderSizePixel = 0, ClipsDescendants = true,
	})
	mk("UICorner", {CornerRadius = UDim.new(0, 6), Parent = card})
	mk("UIStroke", {Parent = card, Color = o.Accent, Thickness = 1, Transparency = 0.4})
	mk("UIPadding", {Parent = card, PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10), PaddingTop = UDim.new(0, 8), PaddingBottom = UDim.new(0, 8)})
	mk("Frame", {
		Parent = card, Position = UDim2.fromOffset(-10, -8),
		Size = UDim2.new(0, 3, 1, 16), BackgroundColor3 = o.Accent, BorderSizePixel = 0,
	})
	mk("UIListLayout", {Parent = card, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2)})
	if title and title ~= "" then
		mk("TextLabel", {
			Parent = card, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 16),
			Font = Enum.Font.GothamBold, Text = tostring(title):upper(),
			TextColor3 = o.Accent, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left,
		})
	end
	mk("TextLabel", {
		Parent = card, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y, Font = Enum.Font.Gotham,
		Text = tostring(msg or ""), TextColor3 = o.Text, TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true,
	})
	tw(card, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0.08})
	task.delay(dur, function()
		local t = tw(card, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1})
		t.Completed:Wait(); pcall(card.Destroy, card)
	end)
end

function GmmUI:NewMenu(name) return Menu.new(self, name) end
function GmmUI:SetTitle(t) self.TitleLabel.Text = tostring(t):upper() end
function GmmUI:SetTab(t) self.TabLabel.Text = tostring(t):upper() end

function GmmUI:_updateCounter()
	local n = self.Current and #self.Current.Items or 0
	local s = n > 0 and math.clamp(self.SelectedIndex, 1, n) or 0
	self.CounterLabel.Text = string.format("%d / %d", s, n)
end

function GmmUI:_saveState()
	local m = self.Current; if not m then return end
	m._si = tonumber(self.SelectedIndex) or 0
	if self.Scroll then
		m._sy = tonumber(self._scrollTgtY or self.Scroll.CanvasPosition.Y) or 0
	end
end

function GmmUI:_clearRows()
	for _, r in ipairs(self._rows) do if r and r.Destroy then r:Destroy() end end
	self._rows = {}; self._rmeta = {}
end

