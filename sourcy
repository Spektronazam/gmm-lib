		ContextActionService:BindActionAtPriority(actionName, fn, false, actionPriority, ...)
	end

	bind("GmmUI_Toggle", function(_, state)
		if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		self:Toggle()
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.F4, Enum.KeyCode.Insert)

	bind("GmmUI_Up", function(_, state)
		if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._edit then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelectedIndex - 1)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Up, Enum.KeyCode.KeypadEight, Enum.KeyCode.I)

	bind("GmmUI_Down", function(_, state)
		if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._edit then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelectedIndex + 1)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Down, Enum.KeyCode.KeypadTwo, Enum.KeyCode.K)

	bind("GmmUI_Left", function(_, state)
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if state == Enum.UserInputState.Begin then
			self:DoLeft()
			self:_startHold(-1)
			return Enum.ContextActionResult.Sink
		elseif state == Enum.UserInputState.End then
			self:_stopHold(-1)
			return Enum.ContextActionResult.Sink
		end
		return Enum.ContextActionResult.Pass
	end, Enum.KeyCode.Left, Enum.KeyCode.KeypadFour, Enum.KeyCode.J)

	bind("GmmUI_Right", function(_, state)
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if state == Enum.UserInputState.Begin then
			self:DoRight()
			self:_startHold(1)
			return Enum.ContextActionResult.Sink
		elseif state == Enum.UserInputState.End then
			self:_stopHold(1)
			return Enum.ContextActionResult.Sink
		end
		return Enum.ContextActionResult.Pass
	end, Enum.KeyCode.Right, Enum.KeyCode.KeypadSix, Enum.KeyCode.L)

	bind("GmmUI_PageUp", function(_, state)
		if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._edit then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelectedIndex - 10)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.PageUp, Enum.KeyCode.KeypadNine)

	bind("GmmUI_PageDown", function(_, state)
		if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._edit then return Enum.ContextActionResult.Sink end
		self:SetSelected(self.SelectedIndex + 10)
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.PageDown, Enum.KeyCode.KeypadThree)

	bind("GmmUI_Back", function(_, state)
		if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		if self._edit then self:CancelEdit() else self:Back() end
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Backspace, Enum.KeyCode.KeypadZero, Enum.KeyCode.U)

	bind("GmmUI_Select", function(_, state)
		if state ~= Enum.UserInputState.Begin then return Enum.ContextActionResult.Pass end
		if not self.Opened then return Enum.ContextActionResult.Pass end
		self:Select()
		return Enum.ContextActionResult.Sink
	end, Enum.KeyCode.Return, Enum.KeyCode.KeypadFive, Enum.KeyCode.O)

	return self
end

GmmUI._checkCapabilities = function(self)
    if self._capabilitiesChecked then return end
    self._capabilitiesChecked = true
    
    self.SupportedFuncs = {}
    local funcs = {"readfile", "writefile", "request", "http_request", "setclipboard", "getgenv", "getrawmetatable", "hookmetamethod", "loadstring", "getsenv", "getcallingscript", "identifyexecutor"}
    
    local env = getfenv(0)
    local genv = type(getgenv) == "function" and getgenv() or env
    
    for _, f in ipairs(funcs) do
        if type(env[f]) == "function" or type(genv[f]) == "function" then
            self.SupportedFuncs[f] = true
        else
            self.SupportedFuncs[f] = false
        end
    end
    
    if self.SupportedFuncs["http_request"] then self.SupportedFuncs["request"] = true end
    if self.SupportedFuncs["request"] then self.SupportedFuncs["http_request"] = true end
end

GmmUI._checkItemSupport = function(self, item)
    self:_checkCapabilities()
    item.Failed = false
    if type(item.Requires) == "table" then
        for _, req in ipairs(item.Requires) do
            if not self.SupportedFuncs[req] then
                item.Failed = true
                item.Desc = "[UNSUPPORTED] " .. tostring(item.Desc)
                break
            end
        end
    end
end

GmmUI.Bootload = function(self, onComplete)
    if self.Opened then self:Close() end
    self:_checkCapabilities()
    
    local total, supported = 0, 0
    for k, v in pairs(self.SupportedFuncs) do
        total = total + 1
        if v then supported = supported + 1 end
    end
    
    local isHighUnc = (supported / total) >= 0.85
    local titleText = "SYSTEM CHECK"
    local bodyText = isHighUnc 
        and "Your executor supports every feature, continue to run?"
        or "Your executor doesn't support some features, run anyways?"
        
    self:_playSound("Notify")
    
    local bootGui = mk("ScreenGui", {
        Name = "GmmBootloader",
        Parent = safeParentGui(),
        DisplayOrder = self.Opts.DisplayOrder + 1,
        ResetOnSpawn = false,
        IgnoreGuiInset = true
    })
    
    local frame = mk("Frame", {
        Parent = bootGui,
        Size = UDim2.new(0, 340, 0, 100),
        Position = UDim2.new(0, -360, 1, -120),
        BackgroundColor3 = Color3.fromRGB(15, 15, 15),
        BorderSizePixel = 0
    })
    addCorner(frame, 4)
    addStroke(frame, self.Opts.Stroke, 0, 1)
    
    local accent = mk("Frame", {
        Parent = frame,
        Size = UDim2.new(0, 6, 1, 0),
        BackgroundColor3 = self.Opts.Accent,
        BorderSizePixel = 0
    })
    addCorner(accent, 4)
    
    local title = mk("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 20, 0, 10),
        Size = UDim2.new(1, -26, 0, 20),
        Font = Enum.Font.ArialBold,
        Text = titleText,
        TextColor3 = self.Opts.Text,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    local body = mk("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 20, 0, 34),
        Size = UDim2.new(1, -30, 0, 36),
        Font = Enum.Font.Arial,
        Text = bodyText,
        TextColor3 = self.Opts.Text,
        TextSize = 14,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top
    })
    
    local hint = mk("TextLabel", {
        Parent = frame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 20, 1, -24),
        Size = UDim2.new(1, -26, 0, 20),
        Font = Enum.Font.ArialBold,
        Text = "[ENTER] YES     [BACKSPACE] NO",
        TextColor3 = self.Opts.MutedText,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    tween(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 20, 1, -120)
    })
    
    local connectionYes
    local connectionNo
    local finalized = false
    
    local function finish(choice)
        if finalized then return end
        finalized = true
        
        if connectionYes then connectionYes:Disconnect() end
        if connectionNo then connectionNo:Disconnect() end
        
        tween(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Position = UDim2.new(0, -360, 1, -120)
        }).Completed:Connect(function()
            bootGui:Destroy()
        end)
        
        if choice then
            self:_playSound("Select")
            task.delay(0.3, function()
                if type(onComplete) == "function" then onComplete() end
                self:Open()
            end)
        else
            self:_playSound("Back")
            task.delay(0.3, function()
                self:Destroy()
            end)
        end
    end
    
    local cas = ContextActionService
    cas:BindActionAtPriority("GmmBoot_Yes", function(_, state)
        if state == Enum.UserInputState.Begin then finish(true) end
        return Enum.ContextActionResult.Sink
    end, false, 99999, Enum.KeyCode.Return, Enum.KeyCode.KeypadEnter)
    
    cas:BindActionAtPriority("GmmBoot_No", function(_, state)
        if state == Enum.UserInputState.Begin then finish(false) end
        return Enum.ContextActionResult.Sink
    end, false, 99999, Enum.KeyCode.Backspace)
    
    connectionYes = {Disconnect = function() cas:UnbindAction("GmmBoot_Yes") end}
    connectionNo = {Disconnect = function() cas:UnbindAction("GmmBoot_No") end}
end

GmmUI.Set3D = function(self, enabled)
    self.Is3D = enabled == true
    if self.Is3D then
        if not self._3dPart then
            local p = Instance.new("Part")
            p.Name = "GmmUI_3D"
            p.Size = Vector3.new(2, 2.5, 0)
            p.Anchored = true
            p.CanCollide = false
            p.Transparency = 1
            p.Parent = Workspace.CurrentCamera
            self._3dPart = p

            local sg = Instance.new("SurfaceGui")
            sg.Name = "GmmUI_Surface"
            sg.Adornee = p
            sg.Parent = safeParentGui()
            sg.AlwaysOnTop = true
            sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
            sg.LightInfluence = 0
            sg.PixelsPerStud = 150
            self._3dSurface = sg
            
            self._3dTargetCF = Workspace.CurrentCamera.CFrame * CFrame.new(-0.8, 0, -3.5) * CFrame.Angles(0, math.rad(10), 0)
            self._3dPart.CFrame = self._3dTargetCF

            self._3dConn = RunService.RenderStepped:Connect(function(dt)
                if not self.Opened then
                    p.CFrame = CFrame.new(0, 10000, 0)
                    return
                end
                local camCF = Workspace.CurrentCamera.CFrame
                -- Sway effect natively locks onto player's view
                self._3dTargetCF = camCF * CFrame.new(-0.8, 0, -3.5) * CFrame.Angles(0, math.rad(10), 0)
                p.CFrame = p.CFrame:Lerp(self._3dTargetCF, math.clamp(dt * 8, 0, 1))
            end)
        end
        self.Main.Parent = self._3dSurface
        self.Main.Position = UDim2.new(0.5, -self.Opts.Size.X.Offset/2, 0.5, -self.Opts.Size.Y.Offset/2)
        self.Shadow.Visible = false
    else
        if self._3dPart then
            self._3dConn:Disconnect()
            self._3dPart:Destroy()
            self._3dPart = nil
            self._3dSurface:Destroy()
            self._3dSurface = nil
        end
        self.Main.Parent = self.Gui
        self.Main.Position = self.Opts.Position
        if self.Opened then self.Shadow.Visible = true end
    end
end

GmmUI._rebuildSounds = function(self)
	if self.SoundFolder then
		self.SoundFolder:Destroy()
		self.SoundFolder = nil
	end

	self.Sounds = {}
	self.SoundFolder = mk("Folder", {
		Name = "GmmUI_Sounds",
		Parent = SoundService
	})

	for name, id in pairs(self.Opts.SoundIds or {}) do
		if tostring(id or "") ~= "" then
			self.Sounds[name] = mk("Sound", {
				Name = name,
				Parent = self.SoundFolder,
				SoundId = tostring(id),
				Volume = tonumber(self.Opts.SoundVolume) or 0.45
			})
		end
	end
end

GmmUI._playSound = function(self, name)
	if not self.Opts.UseSounds then return end

	local template = self.Sounds and self.Sounds[name]
	if not template then return end

	local sound = template:Clone()
	sound.Parent = self.SoundFolder
	sound.Volume = tonumber(self.Opts.SoundVolume) or sound.Volume

	pcall(function() sound:Play() end)

	sound.Ended:Connect(function()
		if sound then sound:Destroy() end
	end)

	task.delay(5, function()
		if sound and sound.Parent then sound:Destroy() end
	end)
end

GmmUI.EnableSounds = function(self, enabled)
	self.Opts.UseSounds = enabled and true or false
end

GmmUI.SetSoundVolume = function(self, volume)
	self.Opts.SoundVolume = math.clamp(tonumber(volume) or self.Opts.SoundVolume or 0.45, 0, 1)
	for _, template in pairs(self.Sounds or {}) do
		template.Volume = self.Opts.SoundVolume
	end
end

