Menu.new = function(ui, name)
	local self = setmetatable({}, Menu)
	self.UI = ui
	self.Name = gtaText(name or "MENU")
	self.Items = {}
	return self
end

Menu._addItem = function(self, item)
    self.UI:_checkItemSupport(item)
	table.insert(self.Items, item)
	return item
end

Menu.Clear = function(self)
	self.Items = {}
	if self.UI and self.UI.Current == self then
		self.UI:_renderMenu(self)
	end
end

Menu.Button = function(self, label, desc, requires, callback)
	if type(requires) == "function" then
		callback = requires
		requires = nil
	end

	return self:_addItem({
		Type = "Button",
		Label = tostring(label),
		Desc = tostring(desc or ""),
        Requires = type(requires) == "table" and requires or {},
		Activate = function(it)
            if it.Failed then
                self.UI:_playSound("Error")
                return
            end
			if typeof(callback) == "function" then
				task.spawn(callback)
			end
		end
	})
end

Menu.Toggle = function(self, label, desc, requires, defaultValue, callback)
	if type(requires) == "boolean" or type(requires) == "nil" then
		callback = defaultValue
		defaultValue = requires
		requires = nil
	end

	local state = defaultValue == true
	return self:_addItem({
		Type = "Toggle",
		Label = tostring(label),
		Desc = tostring(desc or ""),
        Requires = type(requires) == "table" and requires or {},
		Get = function()
			return state
		end,
		Set = function(v)
			state = v and true or false
			if typeof(callback) == "function" then
				task.spawn(callback, state)
			end
		end,
		Left = function(it)
			if not it.Failed then it.Set(not it.Get()) end
		end,
		Right = function(it)
			if not it.Failed then it.Set(not it.Get()) end
		end,
		Activate = function(it)
            if it.Failed then 
                self.UI:_playSound("Error") 
                return 
            end
			it.Set(not it.Get())
		end,
		ValueText = function(it)
			return it.Get() and "ON" or "OFF"
		end
	})
end

Menu.Slider = function(self, label, desc, requires, min, max, step, defaultValue, callback)
	if type(requires) == "number" then
		callback = defaultValue
		defaultValue = step
		step = max
		max = min
		min = requires
		requires = nil
	end

	min = tonumber(min) or 0
	max = tonumber(max) or 100
	step = tonumber(step) or 1

	local value = tonumber(defaultValue)
	if value == nil then value = min end
	value = math.clamp(value, min, max)

	local function set(v)
		v = math.clamp(v, min, max)
		local snapped = min + (math.floor(((v - min) / step) + 0.5) * step)
		value = math.clamp(snapped, min, max)
		if typeof(callback) == "function" then
			task.spawn(callback, value)
		end
	end

	return self:_addItem({
		Type = "Slider",
		Label = tostring(label),
		Desc = tostring(desc or ""),
        Requires = type(requires) == "table" and requires or {},
		Get = function() return value end,
		Set = set,
		Left = function(it)
			if not it.Failed then it.Set(it.Get() - step) end
		end,
		Right = function(it)
			if not it.Failed then it.Set(it.Get() + step) end
		end,
		Activate = function(it)
            if it.Failed then self.UI:_playSound("Error") end
		end,
		ValueText = function(it)
			return tostring(it.Get())
		end
	})
end

Menu.List = function(self, label, desc, arg1, arg2, arg3, arg4)
    local requires, values, defaultIndex, callback
	if type(arg1) == "table" and type(arg2) == "table" then
		requires = arg1
		values = arg2
		defaultIndex = arg3
		callback = arg4
	else
		requires = nil
		values = arg1
		defaultIndex = arg2
		callback = arg3
	end

	values = typeof(values) == "table" and values or {}
	local idx = tonumber(defaultIndex) or 1

	if #values == 0 then
		values = { "N/A" }
		idx = 1
	end

	idx = math.clamp(idx, 1, #values)

	local function setIndex(i)
		idx = ((i - 1) % #values) + 1
		if typeof(callback) == "function" then
			task.spawn(callback, values[idx], idx)
		end
	end

	return self:_addItem({
		Type = "List",
		Label = tostring(label),
		Desc = tostring(desc or ""),
        Requires = requires or {},
		GetIndex = function() return idx end,
		SetIndex = setIndex,
		Left = function(it)
			if not it.Failed then it.SetIndex(it.GetIndex() - 1) end
		end,
		Right = function(it)
			if not it.Failed then it.SetIndex(it.GetIndex() + 1) end
		end,
		Activate = function(it)
            if it.Failed then
                self.UI:_playSound("Error")
            else
			    it.SetIndex(it.GetIndex() + 1)
            end
		end,
		ValueText = function()
			return tostring(values[idx])
		end
	})
end

Menu.Submenu = function(self, label, desc, requires, submenu)
	if type(requires) == "table" and getmetatable(submenu) == Menu then
		-- properly supplied
	elseif getmetatable(requires) == Menu then
		submenu = requires
		requires = nil
	end

	assert(getmetatable(submenu) == Menu, "Submenu must be a Menu created by UI:NewMenu(...)")
	return self:_addItem({
		Type = "Submenu",
		Label = tostring(label),
		Desc = tostring(desc or ""),
        Requires = type(requires) == "table" and requires or {},
		HasArrow = true,
		Activate = function(it)
            if it.Failed then
                self.UI:_playSound("Error")
                return
            end
			self.UI:PushMenu(submenu)
		end
	})
end

