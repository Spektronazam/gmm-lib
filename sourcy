local function deriveTheme(opts)
	opts.Select = opts.Select or Color3.fromRGB(242, 242, 242)
	opts.Panel = opts.Panel or Color3.fromRGB(7, 7, 7)
	opts.Panel2 = opts.Panel2 or Color3.fromRGB(18, 18, 18)
	opts.Row = opts.Row or Color3.fromRGB(28, 28, 28)
	opts.RowHover = opts.RowHover or Color3.fromRGB(42, 42, 42)
	opts.RowSelected = opts.RowSelected or opts.Select
	opts.Pill = opts.Pill or Color3.fromRGB(20, 20, 20)
	opts.Stroke = opts.Stroke or Color3.fromRGB(70, 70, 70)
	opts.MutedText = opts.MutedText or Color3.fromRGB(185, 185, 185)
	opts.HeaderAccent2 = opts.HeaderAccent2 or smartShift(opts.Accent, 0.12)
end

local function buildOptions(userOpts)
	local raw = cloneTable(userOpts or {})
	local base = cloneTable(DEFAULTS)
	local themeValue = raw.Theme
	raw.Theme = nil

	if typeof(themeValue) == "string" and PRESET_THEMES[themeValue] then
		applyTable(base, PRESET_THEMES[themeValue])
	elseif typeof(themeValue) == "table" then
		applyTable(base, themeValue)
	end

	applyTable(base, raw)
	base.Theme = typeof(themeValue) == "string" and themeValue or (typeof(themeValue) == "table" and "Custom" or base.Theme)
	deriveTheme(base)

	return base
end

