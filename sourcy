		Size = UDim2.new(1, 0, 0, 0),
		AutomaticSize = Enum.AutomaticSize.Y,
		Font = Enum.Font.Arial,
		Text = text,
		TextColor3 = self.Opts.Text,
		TextTransparency = 1,
		TextSize = 13,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top
	})

	local lifeBack = mk("Frame", {
		Parent = note,
		AnchorPoint = Vector2.new(0, 1),
		Position = UDim2.new(0, 0, 1, 0),
		Size = UDim2.new(1, 0, 0, 3),
		BackgroundColor3 = Color3.fromRGB(55, 55, 55),
		BackgroundTransparency = 1,
		BorderSizePixel = 0
	})

	local life = mk("Frame", {
		Parent = lifeBack,
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundColor3 = accent,
		BackgroundTransparency = 1,
		BorderSizePixel = 0
	})

	local data = {
		Frame = note, Stroke = noteStroke, TopLine = topLine, Title = titleLabel, Body = bodyLabel, Close = closeButton, Accent = accentBar, LifeBack = lifeBack, Life = life, Kind = kind
	}
	table.insert(self._notifications, data)

	local closed = false
	local function dismiss()
		if closed then return end
		closed = true

		tween(note, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {BackgroundTransparency = 1})
		tween(noteStroke, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {Transparency = 1})
		tween(topLine, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {BackgroundTransparency = 1})
		tween(accentBar, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {BackgroundTransparency = 1})
		tween(titleLabel, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {TextTransparency = 1})
		tween(bodyLabel, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {TextTransparency = 1})
		tween(closeButton, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {TextTransparency = 1})
		tween(lifeBack, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {BackgroundTransparency = 1})
		tween(life, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.In), {BackgroundTransparency = 1})

		task.delay(0.14, function()
			for i = #self._notifications, 1, -1 do
				if self._notifications[i] == data then
					table.remove(self._notifications, i)
					break
				end
			end
			if note then note:Destroy() end
		end)
	end

	closeButton.MouseEnter:Connect(function() closeButton.TextColor3 = self.Opts.Text end)
	closeButton.MouseLeave:Connect(function() closeButton.TextColor3 = self.Opts.MutedText end)
	closeButton.MouseButton1Click:Connect(dismiss)

	tween(note, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {BackgroundTransparency = 0.14})
	tween(noteStroke, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {Transparency = 0.3})
	tween(topLine, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
	tween(accentBar, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
	tween(titleLabel, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(bodyLabel, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(closeButton, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {TextTransparency = 0})
	tween(lifeBack, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
	tween(life, TweenInfo.new(0.12, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {BackgroundTransparency = 0})

	tween(life, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 0, 1, 0)
	})

	if string.lower(tostring(kind)) == "error" then
		self:_playSound("Error")
	else
		self:_playSound("Notify")
	end

	task.delay(duration, dismiss)
	return dismiss
end

GmmUI._applyTheme = function(self)
	local opts = self.Opts
	self.Main.BackgroundColor3 = opts.Panel
	self.MainStroke.Color = opts.Stroke
	self.Header.BackgroundColor3 = opts.Accent
	self.HeaderGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, opts.HeaderAccent2),
		ColorSequenceKeypoint.new(1, darken(opts.Accent, 0.18))
	})
	self.HeaderTopLine.BackgroundColor3 = lighten(opts.Accent, 0.2)
	self.Sub.BackgroundColor3 = opts.Panel2
	self.TitleLabel.TextColor3 = opts.TitleText or opts.Text
	self.TabLabel.TextColor3 = opts.Text
	self.CounterWrap.BackgroundColor3 = opts.Pill
	self.CounterStroke.Color = opts.Stroke
	self.CounterLabel.TextColor3 = opts.Text
	self.Scroll.ScrollBarImageColor3 = opts.Scroller or opts.Accent
	self.Footer.BackgroundColor3 = opts.Panel2
	self.FooterStroke.Color = opts.Stroke
	self.FooterAccent.BackgroundColor3 = opts.Accent
	self.DescLabel.TextColor3 = opts.Text
	self.HintLabel.TextColor3 = opts.MutedText
	self.NotifyHolder.Size = UDim2.fromOffset(opts.NotificationWidth, 0)
	self:_restyleNotifications()

	if self.Current then
		self:_renderMenu(self.Current)
	end
end

GmmUI.SetTheme = function(self, theme)
	local newOpts = cloneTable(self.Opts)

	if typeof(theme) == "string" then
		assert(PRESET_THEMES[theme], "Unknown preset theme: " .. tostring(theme))
		applyTable(newOpts, PRESET_THEMES[theme])
		newOpts.Theme = theme
		self.ThemeName = theme
	elseif typeof(theme) == "table" then
		applyTable(newOpts, theme)
		newOpts.Theme = "Custom"
		self.ThemeName = "Custom"
	end

	deriveTheme(newOpts)
	self.Opts = newOpts
	self:_rebuildSounds()
	self:_applyTheme()
end

GmmUI._makeRow = function(self, item, index)
	local opts = self.Opts
	local hasValue = item.ValueText ~= nil
	local hasArrow = item.HasArrow or item.Type == "Submenu"

	local row = mk("TextButton", {
		Parent = self.Scroll,
		Size = UDim2.new(1, 0, 0, opts.RowHeight),
		BackgroundColor3 = opts.Row,
		BackgroundTransparency = 0.12,
		BorderSizePixel = 0,
		AutoButtonColor = false,
		Text = ""
	})

	local rowStroke = addStroke(row, opts.Stroke, 0.82, 1)

	local selectedBg = mk("Frame", {
		Parent = row,
		Size = UDim2.fromScale(1, 1),
		BackgroundColor3 = opts.RowSelected,
		BackgroundTransparency = 1,
		BorderSizePixel = 0
	})

	mk("UIGradient", {
		Parent = selectedBg,
		Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0, lighten(opts.RowSelected, 0.01)),
			ColorSequenceKeypoint.new(1, darken(opts.RowSelected, 0.08))
		}),
		Rotation = 90
	})

	local accentBar = mk("Frame", {
		Parent = row,
		Size = UDim2.new(0, 4, 1, 0),
		BackgroundColor3 = opts.Accent,
		BackgroundTransparency = 1,
		BorderSizePixel = 0
	})

	mk("Frame", {
		Parent = row,
		AnchorPoint = Vector2.new(0, 1),
		Position = UDim2.new(0, 0, 1, 0),
		Size = UDim2.new(1, 0, 0, 1),
		BackgroundColor3 = opts.Stroke,
		BackgroundTransparency = 0.45,
		BorderSizePixel = 0
	})

	local left = mk("TextLabel", {
		Parent = row,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(12, 0),
		Size = UDim2.new(1, hasValue and -132 or (hasArrow and -30 or -16), 1, 0),
		Font = Enum.Font.ArialBold,
        RichText = true, -- Added for Failed function strikethrough visual
		Text = item.Failed and ("<s>" .. gtaText(item.Label) .. "</s>") or gtaText(item.Label),
		TextColor3 = opts.Text,
		TextSize = 16,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd
	})

	local valueButton, valueStroke, right

	if hasValue then
		valueButton = mk("TextButton", {
			Parent = row,
			AnchorPoint = Vector2.new(1, 0.5),
			Position = UDim2.new(1, hasArrow and -26 or -8, 0.5, 0),
			Size = UDim2.fromOffset(96, opts.RowHeight - 8),
			BackgroundColor3 = opts.Pill,
			BorderSizePixel = 0,
			AutoButtonColor = false,
			Text = ""
		})
		addCorner(valueButton, 0)
		valueStroke = addStroke(valueButton, opts.Stroke, 0.35, 1)

		right = mk("TextLabel", {
			Parent = valueButton,
			BackgroundTransparency = 1,
			Position = UDim2.fromOffset(4, 0),
			Size = UDim2.new(1, -8, 1, 0),
			Font = Enum.Font.ArialBold,
			Text = "",
			TextColor3 = opts.Text,
			TextSize = 14,
			TextXAlignment = Enum.TextXAlignment.Center,
			TextTruncate = Enum.TextTruncate.AtEnd
		})
	end

	local arrow = mk("TextLabel", {
		Parent = row,
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -8, 0.5, 0),
		Size = UDim2.fromOffset(14, 14),
		Font = Enum.Font.ArialBold,
		Text = ">",
		TextColor3 = opts.MutedText,
		TextSize = 18,
		Visible = hasArrow
	})
    
    if item.Failed then
        if valueButton then valueButton.Visible = false end
        arrow.Visible = false
    end

	local selected = false
	local hovered = false

	local function valueBg()
		if selected then return Color3.fromRGB(235, 235, 235) end
		if item.Type == "Toggle" and item.Get and item.Get() then return opts.Accent end
		if item.Type == "Slider" and self._edit and self._edit.Item == item then return mix(opts.Accent, opts.Pill, 0.2) end
		return opts.Pill
	end

	local function valueTextColor()
		if selected then return opts.SelectedText or Color3.fromRGB(12, 12, 12) end
		if item.Type == "Toggle" and item.Get and item.Get() then return Color3.fromRGB(255, 255, 255) end
		return opts.Text
	end

	local function updateValueText()
		if not right then return end
		local value = gtaText(item:ValueText())
		if item.Type == "Slider" and self._edit and self._edit.Item == item then
			right.Text = "< " .. value .. " >"
		elseif item.Type == "List" and selected then
			right.Text = "< " .. value .. " >"
		else
			right.Text = value
		end
	end

	local function applyVisuals(animated)
		local rowColor = hovered and opts.RowHover or opts.Row
		local tColor = selected and (opts.SelectedText or Color3.fromRGB(12, 12, 12)) or opts.Text
        if item.Failed then tColor = opts.MutedText end
		local arrowColor = selected and tColor or opts.MutedText

		if animated then
			tween(row, TweenInfo.new(0.08, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), { BackgroundColor3 = rowColor })
			tween(selectedBg, TweenInfo.new(0.08, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), { BackgroundTransparency = selected and 0 or 1 })
			tween(accentBar, TweenInfo.new(0.08, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), { BackgroundTransparency = selected and 0 or 1 })
			tween(rowStroke, TweenInfo.new(0.08, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
				Color = selected and opts.Accent or opts.Stroke, Transparency = selected and 0.4 or 0.82
			})
		else
			row.BackgroundColor3 = rowColor
			selectedBg.BackgroundTransparency = selected and 0 or 1
			accentBar.BackgroundTransparency = selected and 0 or 1
			rowStroke.Color = selected and opts.Accent or opts.Stroke
			rowStroke.Transparency = selected and 0.4 or 0.82
		end

		left.TextColor3 = tColor
		arrow.TextColor3 = arrowColor

		if right then
			right.TextColor3 = valueTextColor()
			valueButton.BackgroundColor3 = valueBg()
			valueStroke.Color = selected and opts.Accent or opts.Stroke
		end
	end

	local function refreshValue()
		updateValueText()
		applyVisuals(false)
	end

	local function setSelected(on)
		selected = on == true
		updateValueText()
		applyVisuals(true)
	end

	refreshValue()

	row.MouseEnter:Connect(function()
		hovered = true
		applyVisuals(true)
	end)

	row.MouseLeave:Connect(function()
		hovered = false
		applyVisuals(true)
	end)

	row.MouseButton1Click:Connect(function()
		if not self.Opened then return end
        if item.Failed then return end
		if self._edit and self._edit.Item ~= item then return end
		self:SetSelected(index, true)
		self:Select()
	end)

	if valueButton then
		valueButton.MouseEnter:Connect(function() hovered = true; applyVisuals(true) end)
		valueButton.MouseLeave:Connect(function() hovered = false; applyVisuals(true) end)
		valueButton.MouseButton1Down:Connect(function(x)
			if not self.Opened then return end
            if item.Failed then return end
			if self._edit and self._edit.Item ~= item then return end
			self:SetSelected(index, true)

			local mid = valueButton.AbsolutePosition.X + (valueButton.AbsoluteSize.X / 2)
			local dir = (x < mid) and -1 or 1

			if item.Type == "Slider" then
				if not (self._edit and self._edit.Item == item) then self:BeginEdit() end
				if dir < 0 then self:DoLeft() else self:DoRight() end
			elseif item.Type == "List" or item.Type == "Toggle" then
				if dir < 0 then self:DoLeft() else self:DoRight() end
			else
				self:Select()
			end
		end)
	end

	return row, setSelected, refreshValue
end

GmmUI._renderMenu = function(self, menu)
	self:_clearRows()
	self.Current = menu
	self:SetTab(menu.Name)
    
    -- Filter functions dynamically. Fills up supported items, leaving failed ones to occupy the bottom sequentially.
    local sortedItems = {}
    local failedItems = {}
    for _, item in ipairs(menu.Items) do
        if item.Failed then
            table.insert(failedItems, item)
        else
            table.insert(sortedItems, item)
        end
    end
    for _, item in ipairs(failedItems) do
        table.insert(sortedItems, item)
    end
    menu.Items = sortedItems

	for i, item in ipairs(menu.Items) do
		local row, setSelected, refreshValue = self:_makeRow(item, i)
		item.__row = row
		item.__setSelected = setSelected
		item.__refreshValue = refreshValue
		table.insert(self._rowObjects, row)
	end

	if #menu.Items > 0 then
		local savedY = tonumber(menu._savedCanvasY) or 0
		if self._scrollTween then pcall(function() self._scrollTween:Cancel() end); self._scrollTween = nil end

		self.Scroll.CanvasPosition = Vector2.new(0, savedY)
		self._scrollTargetY = savedY

		local savedIdx = tonumber(menu._savedIndex)
		if not (savedIdx and savedIdx >= 1 and savedIdx <= #menu.Items) then savedIdx = 1 end
		self:SetSelected(savedIdx, true)
	else
		self.SelectedIndex = 0
		self.DescLabel.Text = "No options."
		self:_updateCounter()
	end
end

GmmUI.PushMenu = function(self, menu)
	self:_saveMenuState()
	table.insert(self.MenuStack, menu)
	self:_renderMenu(menu)
end

GmmUI.Back = function(self)
	if self._edit then self:CancelEdit(); return end
	if #self.MenuStack <= 1 then self:Close(); return end
	self:_playSound("Back")
	self:_saveMenuState()
	table.remove(self.MenuStack, #self.MenuStack)
	local top = self.MenuStack[#self.MenuStack]
	self:_renderMenu(top)
end

GmmUI._scrollTo = function(self, targetY)
	local scroll = self.Scroll
	if not scroll then return end

	targetY = tonumber(targetY) or 0
	self._scrollTargetY = targetY

	local absCanvasY = scroll.AbsoluteCanvasSize.Y
	local maxY = (absCanvasY > 0) and math.max(0, absCanvasY - scroll.AbsoluteSize.Y) or math.huge
	targetY = math.clamp(targetY, 0, maxY)

	if self._scrollTween then pcall(function() self._scrollTween:Cancel() end); self._scrollTween = nil end

	local smoothness = tonumber(self.Opts and self.Opts.ScrollSmoothness) or 0
	if smoothness <= 0 then
		scroll.CanvasPosition = Vector2.new(0, targetY)
		self._scrollTargetY = targetY
		return
	end

	local duration = math.clamp(0.04 * smoothness, 0.05, 0.3)
	self._scrollTween = tween(scroll, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), {
		CanvasPosition = Vector2.new(0, targetY)
	})
end

GmmUI.SetSelected = function(self, idx, silent)
	if not self.Current then return end

	local items = self.Current.Items
	if #items == 0 then return end

	local previous = self.SelectedIndex
	idx = ((idx - 1) % #items) + 1
	self.SelectedIndex = idx

	for i, it in ipairs(items) do
		if it.__setSelected then it.__setSelected(i == idx) end
	end

	local it = items[idx]
	self.DescLabel.Text = (it and it.Desc and it.Desc ~= "" and it.Desc) or "Select an option."
	self:_updateCounter()

	local row = it and it.__row
	if row then
		local margin = 4
		local y = row.AbsolutePosition.Y
		local h = row.AbsoluteSize.Y
		local topY = self.Scroll.AbsolutePosition.Y
		local botY = topY + self.Scroll.AbsoluteSize.Y

		if y < (topY + margin) then
			self:_scrollTo(self.Scroll.CanvasPosition.Y - ((topY + margin) - y))
		elseif (y + h) > (botY - margin) then
			self:_scrollTo(self.Scroll.CanvasPosition.Y + ((y + h) - (botY - margin)))
		end
	end

	self:_saveMenuState()
	if not silent and previous ~= idx and self.Opened then self:_playSound("Move") end
end

GmmUI._getSelectedItem = function(self)
	if not self.Current then return nil end
	return self.Current.Items[self.SelectedIndex]
end

GmmUI._stopHold = function(self, dir)
	if dir == nil or self._holdDir == dir then
		self._holdDir = nil
		self._holdToken = (self._holdToken or 0) + 1
	end
end

GmmUI._startHold = function(self, dir)
	local it = self._edit and self._edit.Item
	if not (self.Opened and it and it == self:_getSelectedItem() and it.Type == "Slider") then return end

	self._holdDir = dir
	self._holdToken = (self._holdToken or 0) + 1
	local token = self._holdToken

	task.spawn(function()
		task.wait(0.35)
		while self._holdToken == token and self._holdDir == dir do
			if not self.Opened then break end
			if not self._edit or self._edit.Item ~= it then break end
			if dir < 0 then self:DoLeft() else self:DoRight() end
			task.wait(0.05)
		end
	end)
end

GmmUI.BeginEdit = function(self)
	if self._edit then return end
	local it = self:_getSelectedItem()
	if not it or it.Type ~= "Slider" then return end

	self._edit = { Item = it, Original = (it.Get and it.Get()) or nil }
	if it.__refreshValue then it.__refreshValue() end
	self:_playSound("Select")
end

GmmUI.ConfirmEdit = function(self)
	if not self._edit then return end
	local it = self._edit.Item
	self._edit = nil
	self:_stopHold()
	if it and it.__refreshValue then it.__refreshValue() end
	self:_playSound("Select")
end

GmmUI.CancelEdit = function(self)
	if not self._edit then return end
	local it = self._edit.Item
	local original = self._edit.Original
	self._edit = nil
	self:_stopHold()

	if it and original ~= nil and it.Set then it.Set(original) end
	if it and it.__refreshValue then it.__refreshValue() end
	self:_playSound("Back")
end

GmmUI.DoLeft = function(self)
	local it = self:_getSelectedItem()
	if not it then return end
	if it.Type == "Slider" then
		if not (self._edit and self._edit.Item == it) then return end
	end
	if it.Left then
		it:Left()
		if it.__refreshValue then it.__refreshValue() end
		self:_playSound("Change")
	end
end

GmmUI.DoRight = function(self)
	local it = self:_getSelectedItem()
	if not it then return end
	if it.Type == "Slider" then
		if not (self._edit and self._edit.Item == it) then return end
	end
	if it.Right then
		it:Right()
		if it.__refreshValue then it.__refreshValue() end
		self:_playSound("Change")
	end
end

GmmUI.Select = function(self)
	local it = self:_getSelectedItem()
	if not it then return end

	if it.Type == "Slider" then
		if self._edit and self._edit.Item == it then self:ConfirmEdit() else self:BeginEdit() end
		return
	end

	if it.Type == "Toggle" or it.Type == "List" then
		self:_playSound("Change")
	else
		self:_playSound("Select")
	end

	if it.Activate then
		it:Activate()
		if it.__refreshValue then it.__refreshValue() end
	end
end

GmmUI.Open = function(self)
	if self.Opened then return end
	self.Opened = true
    self:_checkCapabilities()
    
	self.Overlay.Visible = true
	self.Shadow.Visible = true
	self.Main.Visible = true

    local endPos, startPos
    if self.Is3D then
        endPos = UDim2.new(0.5, -self.Opts.Size.X.Offset/2, 0.5, -self.Opts.Size.Y.Offset/2)
        startPos = UDim2.new(0, -self.Opts.Size.X.Offset - 50, 0.5, -self.Opts.Size.Y.Offset/2)
    else
        endPos = self.Opts.Position
        startPos = UDim2.new(0, -self.Opts.Size.X.Offset - 50, self.Opts.Position.Y.Scale, self.Opts.Position.Y.Offset)
    end

    self.Main.Position = startPos
    self.Shadow.Position = offsetUDim2(startPos, 4, 6)

	self.Overlay.BackgroundTransparency = 1
	self.Main.BackgroundTransparency = 0.06

	tween(self.Overlay, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.58
	})
	tween(self.Main, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Position = endPos
	})
	tween(self.Shadow, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Position = offsetUDim2(endPos, 4, 6)
	})

	self:_playSound("Open")
end

GmmUI.Close = function(self)
	if not self.Opened then return end
	if self._edit then self:ConfirmEdit() else self:_stopHold() end

	self.Opened = false
	self:_playSound("Close")

    local endPos
    if self.Is3D then
        endPos = UDim2.new(0, -self.Opts.Size.X.Offset - 50, 0.5, -self.Opts.Size.Y.Offset/2)
    else
        endPos = UDim2.new(0, -self.Opts.Size.X.Offset - 50, self.Opts.Position.Y.Scale, self.Opts.Position.Y.Offset)
    end

	local a = tween(self.Overlay, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
		BackgroundTransparency = 1
	})
	tween(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
		Position = endPos
	})
	tween(self.Shadow, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
		Position = offsetUDim2(endPos, 4, 6)
	})

	a.Completed:Connect(function()
		if not self.Opened then
			self.Overlay.Visible = false
			self.Shadow.Visible = false
			self.Main.Visible = false
		end
	end)
end

GmmUI.Toggle = function(self)
	if self.Opened then self:Close() else self:Open() end
end

GmmUI.Destroy = function(self)
	for _, c in ipairs(self._connections) do pcall(function() c:Disconnect() end) end
	self._connections = {}

	if self._casActions then
		for _, name in ipairs(self._casActions) do
			pcall(function() ContextActionService:UnbindAction(name) end)
		end
		self._casActions = nil
	end
    
    if self._3dPart then self._3dPart:Destroy(); self._3dPart = nil end
    if self._3dSurface then self._3dSurface:Destroy(); self._3dSurface = nil end
    if self._3dConn then self._3dConn:Disconnect(); self._3dConn = nil end

	if self.SoundFolder then self.SoundFolder:Destroy(); self.SoundFolder = nil end
	if self.Gui then self.Gui:Destroy() end
end

return GmmUI
