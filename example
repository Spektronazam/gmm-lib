	Settings.CurrentTheme = theme
	ui:SetTheme(theme)
	notify("STYLE CHANGED", theme .. " loaded.", 2.5, "Success")
end)

local rebuildSavedLocationMenu
local refreshPlayerList

rebuildSavedLocationMenu = function()
	savedLocMenu:Clear()

	savedLocMenu:Button("Save Current Position", "Store your current spot.", function()
		local name = "LOCATION " .. tostring(#Settings.SavedLocations + 1)
		saveLocation(name)
		rebuildSavedLocationMenu()
		notify("TELEPORT", name .. " saved.", 2, "Success")
	end)

	savedLocMenu:Button("Clear All Saved", "Remove all saved spots.", function()
		Settings.SavedLocations = {}
		rebuildSavedLocationMenu()
		notify("TELEPORT", "All saved locations removed.", 2.5, "Warning")
	end)

	for _, entry in ipairs(Settings.SavedLocations) do
		savedLocMenu:Button(entry.Name, "Teleport to " .. entry.Name .. ".", function()
			teleportTo(entry.Position + Vector3.new(0, 3, 0))
			notify("TELEPORT", "Moved to " .. entry.Name .. ".", 2, "Success")
		end)
	end
end

refreshPlayerList = function()
	tpPlayerMenu:Clear()

	tpPlayerMenu:Button("Refresh Player List", "Reload the current players.", function()
		refreshPlayerList()
		notify("PLAYERS", "Player list refreshed.", 2, "Success")
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			tpPlayerMenu:Button(player.Name, "Teleport near " .. player.Name .. ".", function()
				teleportToPlayer(player.Name)
			end)
		end
	end
end

rebuildSavedLocationMenu()
refreshPlayerList()

Players.PlayerAdded:Connect(function()
	task.defer(refreshPlayerList)
end)

Players.PlayerRemoving:Connect(function()
	task.defer(refreshPlayerList)
end)

LocalPlayer.CharacterAdded:Connect(function()
	applyCurrentCharacterState()
end)

ui:PushMenu(homeMenu)
notify("INTERACTION MENU", "Loaded successfully.", 3, "Success")
