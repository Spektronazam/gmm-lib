local GmmUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Spektronazam/gmm-lib/refs/heads/main/source?t=" .. tick()))()

local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local function getCharacter()
	return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getHumanoid()
	local character = getCharacter()
	return character and character:FindFirstChildOfClass("Humanoid")
end

local function getRootPart()
	local character = getCharacter()
	return character and character:FindFirstChild("HumanoidRootPart")
end

local Settings = {
	GodMode = false,
	SuperJump = false,
	FastWalk = false,
	FastWalkSpeed = 16,
	Invisible = false,
	FreezeTime = false,
	FrozenTime = 12,
	CurrentTheme = "GTA5",
	SavedLocations = {}
}

local DefaultLighting = {
	Brightness = Lighting.Brightness,
	Ambient = Lighting.Ambient,
	OutdoorAmbient = Lighting.OutdoorAmbient,
	FogEnd = Lighting.FogEnd,
	FogStart = Lighting.FogStart,
	FogColor = Lighting.FogColor
}

local ui
local freezeConnection

local function notify(title, text, duration, kind)
	if ui then
		ui:Notify(title, text, duration, kind)
	end
end

local function healPlayer()
	local humanoid = getHumanoid()
	if humanoid then
		humanoid.Health = humanoid.MaxHealth
	end
end

local function setGodMode(enabled)
	Settings.GodMode = enabled
	local humanoid = getHumanoid()
	if humanoid then
		if enabled then
			humanoid.MaxHealth = math.huge
			humanoid.Health = math.huge
		else
			humanoid.MaxHealth = 100
			humanoid.Health = math.min(humanoid.Health, 100)
		end
	end
end

local function setSuperJump(enabled)
	Settings.SuperJump = enabled
	local humanoid = getHumanoid()
	if humanoid then
		if enabled then
			humanoid.JumpPower = 120
			humanoid.UseJumpPower = true
		else
			humanoid.JumpPower = 50
			humanoid.UseJumpPower = true
		end
	end
end

local function setWalkSpeed(speed)
	Settings.FastWalkSpeed = speed
	local humanoid = getHumanoid()
	if humanoid then
		if Settings.FastWalk then
			humanoid.WalkSpeed = speed
		else
			humanoid.WalkSpeed = 16
		end
	end
end

local function setFastWalk(enabled)
	Settings.FastWalk = enabled
	local humanoid = getHumanoid()
	if humanoid then
		humanoid.WalkSpeed = enabled and Settings.FastWalkSpeed or 16
	end
end

local function setInvisible(enabled)
	Settings.Invisible = enabled
	local character = getCharacter()
	if not character then
		return
	end

	for _, obj in ipairs(character:GetDescendants()) do
		if obj:IsA("BasePart") then
			obj.LocalTransparencyModifier = enabled and 1 or 0
		elseif obj:IsA("Decal") then
			obj.Transparency = enabled and 1 or 0
		end
	end
end

local function setTime(hour)
	Settings.FrozenTime = hour
	Lighting.ClockTime = hour
end

local function setFreezeTime(enabled)
	Settings.FreezeTime = enabled

	if freezeConnection then
		freezeConnection:Disconnect()
		freezeConnection = nil
	end

	if enabled then
		Settings.FrozenTime = Lighting.ClockTime
		freezeConnection = RunService.RenderStepped:Connect(function()
			Lighting.ClockTime = Settings.FrozenTime
		end)
	end
end

local WeatherTypes = { "CLEAR", "FOGGY", "RAINY", "SUNSET", "NIGHT" }

local function setWeather(weatherType)
	Lighting.Brightness = DefaultLighting.Brightness
	Lighting.Ambient = DefaultLighting.Ambient
	Lighting.OutdoorAmbient = DefaultLighting.OutdoorAmbient
	Lighting.FogEnd = DefaultLighting.FogEnd
	Lighting.FogStart = DefaultLighting.FogStart
	Lighting.FogColor = DefaultLighting.FogColor

	if weatherType == "CLEAR" then
		Lighting.Brightness = 2
		Lighting.FogEnd = 100000
	elseif weatherType == "FOGGY" then
		Lighting.Brightness = 1.4
		Lighting.FogStart = 0
		Lighting.FogEnd = 220
		Lighting.FogColor = Color3.fromRGB(200, 200, 200)
	elseif weatherType == "RAINY" then
		Lighting.Brightness = 0.7
		Lighting.FogStart = 0
		Lighting.FogEnd = 600
		Lighting.Ambient = Color3.fromRGB(80, 80, 95)
		Lighting.OutdoorAmbient = Color3.fromRGB(65, 65, 80)
	elseif weatherType == "SUNSET" then
		Lighting.ClockTime = 18.3
		Lighting.Brightness = 1.7
		Lighting.Ambient = Color3.fromRGB(255, 170, 120)
	elseif weatherType == "NIGHT" then
		Lighting.ClockTime = 0
		Lighting.Brightness = 0.4
		Lighting.Ambient = Color3.fromRGB(45, 45, 60)
		Lighting.OutdoorAmbient = Color3.fromRGB(25, 25, 40)
	end
end

local function setGravity(value)
	Workspace.Gravity = value
end

local function teleportTo(position)
	local rootPart = getRootPart()
	if rootPart then
		rootPart.CFrame = CFrame.new(position)
	end
end

local function teleportToPlayer(playerName)
	local targetPlayer = Players:FindFirstChild(playerName)
	if not targetPlayer or not targetPlayer.Character then
		notify("TELEPORT", "Player not found.", 2.5, "Error")
		return
	end

	local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
	if not targetRoot then
		notify("TELEPORT", "Target has no root part.", 2.5, "Error")
		return
	end

	teleportTo(targetRoot.Position + Vector3.new(3, 0, 0))
	notify("TELEPORT", "Moved near " .. targetPlayer.Name .. ".", 2.5, "Success")
end

local function saveLocation(name)
	local rootPart = getRootPart()
	if not rootPart then
		return
	end

	table.insert(Settings.SavedLocations, {
		Name = name,
		Position = rootPart.Position
	})
end

local function applyCurrentCharacterState()
	task.wait(0.75)
	setGodMode(Settings.GodMode)
	setSuperJump(Settings.SuperJump)
	setFastWalk(Settings.FastWalk)
	setWalkSpeed(Settings.FastWalkSpeed)
	setInvisible(Settings.Invisible)
end

